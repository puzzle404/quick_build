<div style="padding:14px 16px;border-right:1px solid var(--color-line);<%= 'background:var(--color-bg-sunken);' if highlight %>position:relative;display:flex;flex-direction:column;gap:8px;">
  <div style="display:flex;align-items:center;gap:6px;color:var(--color-ink-3);font-size:11px;font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.8px;font-weight:500;">
    <%= label %>
  </div>
  <div style="display:flex;align-items:baseline;gap:6px;">
    <div class="qb-mono qb-tnum" style="font-size:26px;font-weight:500;letter-spacing:-0.5px;color:var(--color-ink);line-height:1;"><%= value %></div>
    <% if suffix %><div class="qb-mono" style="font-size:13px;color:var(--color-ink-3);"><%= suffix %></div><% end %>
  </div>
  <div style="display:flex;align-items:center;justify-content:space-between;">
    <div style="font-size:11px;color:<%= hint_color %>;display:flex;align-items:center;gap:4px;">
      <% if tone == :ok %><%= render Qb::IconComponent.new(name: :'arrow-up', size: 11) %><% end %>
      <% if tone == :warn %><%= render Qb::IconComponent.new(name: :alert, size: 11) %><% end %>
      <%= hint %>
    </div>
    <% if data&.any? %>
      <%= render Qb::SparkComponent.new(data: data, w: 68, h: 22, tone: spark_tone) %>
    <% end %>
  </div>
</div>
