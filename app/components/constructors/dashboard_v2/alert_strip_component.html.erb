<div>
  <% if alerts.empty? %>
    <div style="padding:24px 16px;text-align:center;color:var(--color-ink-3);font-size:12px;">Sin alertas activas.</div>
  <% else %>
    <% alerts.each do |a| %>
      <div style="display:flex;align-items:flex-start;gap:10px;padding:10px 16px;border-bottom:1px solid var(--color-line);">
        <div style="margin-top:2px;"><%= render Qb::StatusDotComponent.new(tone: a[:tone]) %></div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:12px;color:var(--color-ink);font-weight:500;"><%= a[:message] %></div>
          <div style="font-size:11px;color:var(--color-ink-3);margin-top:2px;">
            <span class="qb-mono" style="color:var(--color-ink-4);"><%= a[:project] %></span> · <%= a[:when] %>
          </div>
        </div>
        <%= render Qb::BtnComponent.new('Revisar', variant: :ghost, size: :xs) %>
      </div>
    <% end %>
  <% end %>
</div>
