<div style="padding:16px 16px 8px;">
  <%# 'safe to inline as a literal string because all values are numeric — no XSS surface' %>
  <%= raw(<<~SVG)
    <svg width="100%" viewBox="0 0 #{W} #{H}" style="max-height:220px;">
      <defs>
        <linearGradient id="qbDashPlanFill" x1="0" x2="0" y1="0" y2="1">
          <stop offset="0%" stop-color="var(--color-accent)" stop-opacity="0.12"/>
          <stop offset="100%" stop-color="var(--color-accent)" stop-opacity="0"/>
        </linearGradient>
      </defs>
      #{[0, 25, 50, 75, 100].map { |p|
        %(<g>
          <line x1="#{PAD_L}" x2="#{W - PAD_R}" y1="#{y_line(p)}" y2="#{y_line(p)}" stroke="var(--color-line)" stroke-dasharray="#{p == 0 ? '' : '2 3'}"/>
          <text x="#{PAD_L - 8}" y="#{y_line(p) + 3}" font-size="10" text-anchor="end" fill="var(--color-ink-4)" font-family="var(--font-mono)">#{p}%</text>
        </g>)
      }.join}
      #{spend.each_with_index.map { |v, i|
        x = (x_at(i) - 14).round(1)
        y = y_bar(v).round(1)
        h = (PAD_T + ih - y).round(1)
        %(<rect x="#{x}" y="#{y}" width="28" height="#{h}" fill="color-mix(in oklab, var(--color-accent) 22%, var(--color-line))" opacity=".55"/>)
      }.join}
      <polygon points="#{progress_area_points}" fill="url(#qbDashPlanFill)"/>
      <polyline points="#{line_points(plan)}" fill="none" stroke="var(--color-ink-3)" stroke-width="1.2" stroke-dasharray="3 3"/>
      <polyline points="#{line_points(progress)}" fill="none" stroke="var(--color-accent)" stroke-width="2"/>
      #{progress.each_with_index.map { |v, i| %(<circle cx="#{x_at(i).round(1)}" cy="#{y_line(v).round(1)}" r="2.8" fill="var(--color-accent)"/>) }.join}
      #{months.each_with_index.map { |m, i| %(<text x="#{x_at(i).round(1)}" y="#{H - 6}" font-size="10" text-anchor="middle" fill="var(--color-ink-3)" font-family="var(--font-mono)">#{ERB::Util.html_escape(m)}</text>) }.join}
      #{[0, max_s / 2.0, max_s].each_with_index.map { |v, _i| %(<text x="#{W - PAD_R + 8}" y="#{y_bar(v).round(1) + 3}" font-size="10" fill="var(--color-ink-4)" font-family="var(--font-mono)">#{short_ars(v)}</text>) }.join}
    </svg>
  SVG
  %>
  <div style="display:flex;gap:16px;font-size:11px;color:var(--color-ink-3);padding:0 44px;">
    <span style="display:inline-flex;align-items:center;gap:6px;"><span style="width:14px;height:2px;background:var(--color-accent);display:inline-block;"></span>Avance real</span>
    <span style="display:inline-flex;align-items:center;gap:6px;"><span style="width:14px;height:0;border-top:2px dashed var(--color-ink-3);display:inline-block;"></span>Plan</span>
    <span style="display:inline-flex;align-items:center;gap:6px;"><span style="width:10px;height:10px;background:color-mix(in oklab, var(--color-accent) 22%, var(--color-line));display:inline-block;"></span>Gasto mensual (ARS)</span>
  </div>
</div>
