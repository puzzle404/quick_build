<details class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <summary class="cursor-pointer select-none text-sm font-semibold text-indigo-600 hover:text-indigo-700">
    Nuevo gasto
  </summary>

  <div class="mt-5">
    <%= form_with url: form_url, scope: :expense, multipart: true, class: "space-y-4" do |form| %>
      <% if expense.errors.any? %>
        <div class="rounded-lg border border-red-200 bg-red-50 p-3 text-sm text-red-700">
          <p class="font-semibold">No pudimos guardar el gasto:</p>
          <ul class="mt-1 list-disc pl-4">
            <% expense.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <%= form.label :incurred_on, "Fecha", class: "block text-sm font-medium text-slate-700" %>
          <%= form.date_field :incurred_on, value: expense.incurred_on || Date.today, class: "mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-emerald-500" %>
        </div>

        <div>
          <%= form.label :amount_cents, "Monto (centavos)", class: "block text-sm font-medium text-slate-700" %>
          <%= form.number_field :amount_cents, min: 1, required: true, value: expense.amount_cents, class: "mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-emerald-500" %>
        </div>
      </div>

      <div>
        <%= form.label :category, "Categoría", class: "block text-sm font-medium text-slate-700" %>
        <%= form.select :category, category_options, { selected: expense.category, prompt: "Seleccionar categoría" }, class: "mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-emerald-500" %>
      </div>

      <div>
        <%= form.label :description, "Descripción", class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_area :description, rows: 2, value: expense.description, class: "mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-emerald-500" %>
      </div>

      <div>
        <%= form.label :receipt, "Comprobante (JPG, PNG, PDF)", class: "block text-sm font-medium text-slate-700" %>
        <%= form.file_field :receipt, accept: "image/jpeg,image/png,application/pdf", class: "mt-1 block w-full text-sm text-slate-500 file:mr-3 file:rounded-lg file:border-0 file:bg-indigo-50 file:px-3 file:py-1.5 file:text-sm file:font-medium file:text-indigo-700 hover:file:bg-indigo-100" %>
      </div>

      <div class="flex justify-end">
        <%= render Ui::ButtonComponent.new(label: "Registrar gasto", type: :submit, size: :md, variant: :primary, class_name: "!rounded-lg") %>
      </div>
    <% end %>
  </div>
</details>
