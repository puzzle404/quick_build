<details style="border:1px solid var(--color-line);border-radius:6px;background:var(--color-bg-raised);padding:12px 14px;">
  <summary style="cursor:pointer;user-select:none;font-size:11px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.7px;list-style:none;">
    Nuevo gasto
  </summary>

  <div style="margin-top:12px;">
    <%= form_with url: form_url, scope: :expense, multipart: true do |form| %>
      <% if expense.errors.any? %>
        <div style="border:1px solid var(--color-bad);border-radius:6px;background:color-mix(in oklab, var(--color-bad) 10%, transparent);padding:10px 12px;font-size:12px;color:var(--color-bad);margin-bottom:12px;">
          <p style="font-weight:600;margin:0 0 4px;">No pudimos guardar el gasto:</p>
          <ul style="margin:0;padding-left:16px;">
            <% expense.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">
        <div>
          <%= form.label :incurred_on, "Fecha", style: "display:block;font-size:11px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;" %>
          <%= form.date_field :incurred_on, value: expense.incurred_on || Date.today,
                style: "display:block;width:100%;border:1px solid var(--color-line);border-radius:5px;padding:5px 8px;font-size:12px;background:var(--color-bg);color:var(--color-ink);outline:none;" %>
        </div>

        <div>
          <%= form.label :amount_cents, "Monto (centavos)", style: "display:block;font-size:11px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;" %>
          <%= form.number_field :amount_cents, min: 1, required: true, value: expense.amount_cents,
                style: "display:block;width:100%;border:1px solid var(--color-line);border-radius:5px;padding:5px 8px;font-size:12px;background:var(--color-bg);color:var(--color-ink);outline:none;" %>
        </div>
      </div>

      <div style="margin-bottom:10px;">
        <%= form.label :category, "Categoría", style: "display:block;font-size:11px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;" %>
        <%= form.select :category, category_options, { selected: expense.category, prompt: "Seleccionar categoría" },
              style: "display:block;width:100%;border:1px solid var(--color-line);border-radius:5px;padding:5px 8px;font-size:12px;background:var(--color-bg);color:var(--color-ink);outline:none;" %>
      </div>

      <div style="margin-bottom:10px;">
        <%= form.label :description, "Descripción", style: "display:block;font-size:11px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;" %>
        <%= form.text_area :description, rows: 2, value: expense.description,
              style: "display:block;width:100%;border:1px solid var(--color-line);border-radius:5px;padding:5px 8px;font-size:12px;background:var(--color-bg);color:var(--color-ink);outline:none;resize:vertical;" %>
      </div>

      <div style="margin-bottom:12px;">
        <%= form.label :receipt, "Comprobante (JPG, PNG, PDF)", style: "display:block;font-size:11px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:4px;" %>
        <%= form.file_field :receipt, accept: "image/jpeg,image/png,application/pdf",
              style: "display:block;font-size:12px;color:var(--color-ink-2);width:100%;" %>
      </div>

      <div style="display:flex;justify-content:flex-end;">
        <%= render Qb::BtnComponent.new('Registrar gasto', variant: :primary, size: :sm, type: 'submit') %>
      </div>
    <% end %>
  </div>
</details>
