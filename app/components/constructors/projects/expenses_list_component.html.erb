<div>
  <div style="font-size:11px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:8px;">
    Gastos · <%= expenses.size %>
  </div>

  <% if expenses.empty? %>
    <div style="padding:14px;text-align:center;color:var(--color-ink-4);font-size:12px;border:1px dashed var(--color-line);border-radius:6px;">
      Todavía no se registraron gastos.
    </div>
  <% else %>
    <div style="border:1px solid var(--color-line);border-radius:6px;overflow:hidden;">
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="background:var(--color-bg-sunken);">
            <th style="padding:6px 10px;text-align:left;font-size:10px;font-family:var(--font-mono);color:var(--color-ink-4);text-transform:uppercase;letter-spacing:0.5px;font-weight:500;">Fecha</th>
            <th style="padding:6px 10px;text-align:left;font-size:10px;font-family:var(--font-mono);color:var(--color-ink-4);text-transform:uppercase;letter-spacing:0.5px;font-weight:500;">Categoría</th>
            <th style="padding:6px 10px;text-align:left;font-size:10px;font-family:var(--font-mono);color:var(--color-ink-4);text-transform:uppercase;letter-spacing:0.5px;font-weight:500;">Descripción</th>
            <th style="padding:6px 10px;text-align:right;font-size:10px;font-family:var(--font-mono);color:var(--color-ink-4);text-transform:uppercase;letter-spacing:0.5px;font-weight:500;">Monto</th>
            <th style="padding:6px 10px;"></th>
          </tr>
        </thead>
        <tbody>
          <% expenses.each do |expense| %>
            <tr style="border-top:1px solid var(--color-line);background:var(--color-bg-raised);">
              <td style="padding:7px 10px;font-size:12px;color:var(--color-ink-2);font-family:var(--font-mono);white-space:nowrap;"><%= expense.incurred_on.strftime("%d/%m/%Y") %></td>
              <td style="padding:7px 10px;font-size:12px;color:var(--color-ink-2);"><%= category_label(expense) %></td>
              <td style="padding:7px 10px;font-size:12px;color:var(--color-ink);"><%= expense.description %></td>
              <td style="padding:7px 10px;text-align:right;font-size:12px;font-weight:500;color:var(--color-ink);font-family:var(--font-mono);" class="qb-tnum"><%= helpers.qb_fmt_cents(expense.amount_cents) %></td>
              <td style="padding:7px 10px;text-align:right;">
                <%= render Qb::BtnComponent.new('Eliminar', variant: :danger, size: :xs,
                      href: delete_path(expense),
                      data: { turbo_method: :delete, turbo_confirm: '¿Eliminar este gasto?' }) %>
              </td>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <tr style="border-top:1px solid var(--color-line);background:var(--color-bg-sunken);">
            <td colspan="3" style="padding:7px 10px;font-size:12px;font-weight:600;color:var(--color-ink);font-family:var(--font-mono);text-transform:uppercase;letter-spacing:0.5px;">Total</td>
            <td style="padding:7px 10px;text-align:right;font-size:12px;font-weight:600;color:var(--color-ink);font-family:var(--font-mono);" class="qb-tnum"><%= helpers.qb_fmt_cents(total_cents) %></td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>
  <% end %>
</div>
