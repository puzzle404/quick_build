<%= link_to helpers.constructors_project_path(project), style: 'text-align:left;border:1px solid var(--color-line);border-radius:8px;background:var(--color-bg-raised);padding:14px;cursor:pointer;display:flex;flex-direction:column;gap:10px;text-decoration:none;color:inherit;' do %>
  <div style="display:flex;align-items:center;gap:8px;">
    <span class="qb-mono" style="font-size:10px;color:var(--color-ink-3);background:var(--color-bg-sunken);padding:2px 6px;border-radius:3px;"><%= project.code %></span>
    <%= render Qb::PillComponent.new(tone: project.status_tone, compact: true) { project.status_label } %>
    <div style="flex:1;"></div>
    <%= render Qb::StatusDotComponent.new(tone: project.health) %>
  </div>
  <div>
    <div style="font-weight:600;font-size:14px;line-height:1.3;color:var(--color-ink);"><%= project.name %></div>
    <div style="font-size:11px;color:var(--color-ink-3);margin-top:3px;"><%= project.client.presence || '—' %> · <%= project.location_label %></div>
  </div>
  <div style="display:flex;align-items:baseline;gap:8px;">
    <span class="qb-mono qb-tnum" style="font-size:22px;font-weight:500;letter-spacing:-0.4px;color:var(--color-ink);"><%= project.progress %>%</span>
    <span class="qb-mono" style="font-size:11px;color:var(--color-ink-4);">plan <%= project.planned_progress %>%</span>
  </div>
  <%= render Qb::BarComponent.new(value: project.progress, plan: project.planned_progress, show_plan: true, tone: bar_tone) %>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;padding-top:8px;border-top:1px solid var(--color-line);">
    <div>
      <div class="qb-mono" style="font-size:9.5px;color:var(--color-ink-4);text-transform:uppercase;letter-spacing:0.6px;">Presupuesto</div>
      <div class="qb-mono qb-tnum" style="font-size:12px;font-weight:500;color:var(--color-ink);"><%= helpers.qb_fmt_ars(project.spent) %> <span style="color:var(--color-ink-4);font-weight:400;">/ <%= used_pct %>%</span></div>
    </div>
    <div>
      <div class="qb-mono" style="font-size:9.5px;color:var(--color-ink-4);text-transform:uppercase;letter-spacing:0.6px;">Etapas</div>
      <div class="qb-mono qb-tnum" style="font-size:12px;font-weight:500;color:var(--color-ink);"><%= project.stages_done %>/<%= project.stages_count %> · <%= project.people_count %> pers</div>
    </div>
  </div>
<% end %>
