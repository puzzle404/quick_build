<details class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <summary class="cursor-pointer select-none text-sm font-semibold text-indigo-600 hover:text-indigo-700">
    Nueva nota
  </summary>

  <div class="mt-5">
    <%= form_with url: form_url, scope: :note, class: "space-y-4" do |form| %>
      <div>
        <%= form.label :title, "Título (opcional)", class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :title, class: "mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-emerald-500" %>
      </div>

      <div>
        <%= form.label :body, "Nota", class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_area :body, rows: 4, required: true, class: "mt-1 block w-full rounded-lg border border-slate-300 px-3 py-2 text-sm shadow-sm focus:border-emerald-500 focus:outline-none focus:ring-emerald-500" %>
      </div>

      <div class="flex justify-end">
        <%= render Ui::ButtonComponent.new(label: "Agregar nota", type: :submit, size: :md, variant: :primary, class_name: "!rounded-lg") %>
      </div>
    <% end %>
  </div>
</details>
