<section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h2 class="text-lg font-semibold text-slate-900">Notas</h2>
      <p class="text-sm text-slate-500">Notas y observaciones sobre este elemento.</p>
    </div>
  </div>

  <% if notes.empty? %>
    <p class="mt-5 text-sm text-slate-500">Aún no hay notas.</p>
  <% else %>
    <div class="mt-5 space-y-4">
      <% notes.each do |note| %>
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <% if note.title.present? %>
                <h3 class="text-sm font-semibold text-slate-900"><%= note.title %></h3>
              <% end %>
              <div class="mt-1 text-sm text-slate-700">
                <%= simple_format(note.body, class: "prose-sm") %>
              </div>
              <p class="mt-2 text-xs text-slate-400">
                <%= note.author.email %> &middot; <%= time_ago_in_words(note.created_at) %> atrás
              </p>
            </div>
            <div class="shrink-0">
              <%= render Ui::ButtonComponent.new(
                    label: "Eliminar",
                    path: delete_path(note),
                    turbo_method: :delete,
                    variant: :danger,
                    size: :sm,
                    turbo_confirm: "¿Eliminar esta nota?",
                    class_name: "!px-2.5 !py-1 !rounded-md"
                  ) %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</section>
