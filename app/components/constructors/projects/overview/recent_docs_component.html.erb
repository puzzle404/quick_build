<div>
  <% if documents.empty? %>
    <div style="padding:20px;text-align:center;color:var(--color-ink-3);font-size:12px;">No hay documentos cargados todavía.</div>
  <% else %>
    <% documents.first(4).each do |d| %>
      <div style="display:flex;align-items:center;gap:10px;padding:8px 14px;border-bottom:1px solid var(--color-line);">
        <span class="qb-mono" style="font-size:10px;width:32px;padding:2px 4px;background:var(--color-bg-sunken);border:1px solid var(--color-line);border-radius:3px;text-align:center;color:var(--color-ink-3);"><%= kind_for(d) %></span>
        <div style="flex:1;min-width:0;">
          <div style="font-size:12px;color:var(--color-ink);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;"><%= name_for(d) %></div>
          <div style="font-size:10px;color:var(--color-ink-4);"><%= uploader_for(d) %> · <%= at_for(d) %></div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
