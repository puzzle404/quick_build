<div style="padding:12px;display:flex;flex-direction:column;gap:8px;">
  <% if items.empty? %>
    <div style="padding:16px;text-align:center;color:var(--color-ink-3);font-size:12px;border:1px dashed var(--color-line);border-radius:6px;">Sin riesgos detectados.</div>
  <% else %>
    <% items.each do |r| %>
      <div style="padding:10px;border:1px solid var(--color-line);border-radius:6px;background:var(--color-bg-raised);display:flex;gap:10px;">
        <%= render Qb::StatusDotComponent.new(tone: r[:tone]) %>
        <div style="flex:1;">
          <div style="font-size:12px;font-weight:600;color:var(--color-ink);"><%= r[:title] %></div>
          <div style="font-size:11px;color:var(--color-ink-3);margin-top:3px;"><%= r[:body] %></div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
