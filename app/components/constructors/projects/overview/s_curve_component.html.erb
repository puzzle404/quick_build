<div style="padding:16px;">
  <%= raw(<<~SVG)
    <svg width="100%" viewBox="0 0 #{W} #{H}">
      #{[0, 25, 50, 75, 100].map { |v|
        %(<g>
          <line x1="#{PAD_L}" x2="#{W - PAD_R}" y1="#{y_at(v)}" y2="#{y_at(v)}" stroke="var(--color-line)" stroke-dasharray="#{v == 0 ? '' : '2 3'}"/>
          <text x="#{PAD_L - 6}" y="#{y_at(v) + 3}" font-size="10" text-anchor="end" fill="var(--color-ink-4)" font-family="var(--font-mono)">#{v}%</text>
        </g>)
      }.join}
      <polyline points="#{plan_area_points}" fill="var(--color-line)" opacity=".5"/>
      <polyline points="#{points(plan)}" fill="none" stroke="var(--color-ink-3)" stroke-width="1.2" stroke-dasharray="3 3"/>
      <polyline points="#{points(data)}" fill="none" stroke="var(--color-accent)" stroke-width="2"/>
      #{data.each_with_index.map { |v, i| %(<circle cx="#{x_at(i).round(1)}" cy="#{y_at(v).round(1)}" r="2.5" fill="var(--color-accent)"/>) }.join}
      <line x1="#{x_at(today_idx)}" x2="#{x_at(today_idx)}" y1="#{PAD_T}" y2="#{PAD_T + ih}" stroke="var(--color-accent)" stroke-dasharray="2 3" stroke-width="1"/>
      <text x="#{x_at(today_idx) + 6}" y="#{PAD_T + 12}" font-size="10" fill="var(--color-accent)" font-family="var(--font-mono)">HOY · #{today_progress}%</text>
      <text x="#{x_at(today_idx) + 6}" y="#{PAD_T + 26}" font-size="10" fill="var(--color-ink-3)" font-family="var(--font-mono)">Plan #{today_plan}% · Δ#{today_progress - today_plan}</text>
      #{month_labels.each_with_index.map { |m, i| %(<text x="#{x_at(i).round(1)}" y="#{H - 6}" font-size="10" text-anchor="middle" fill="var(--color-ink-3)" font-family="var(--font-mono)">#{m}</text>) }.join}
    </svg>
  SVG
  %>
</div>
