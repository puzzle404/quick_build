<div style="padding:12px;display:flex;flex-wrap:wrap;gap:6px;">
  <% if members.empty? %>
    <div style="padding:12px;color:var(--color-ink-3);font-size:12px;">Aún no hay equipo asignado.</div>
  <% else %>
    <% members.each do |m| %>
      <div style="display:flex;align-items:center;gap:8px;padding:6px 10px 6px 6px;border:1px solid var(--color-line);border-radius:999px;background:var(--color-bg-raised);">
        <%= render Qb::AvatarComponent.new(name: short_name(m), size: 20) %>
        <div style="font-size:12px;font-weight:500;"><%= short_name(m) %></div>
        <% if role(m) %>
          <span class="qb-mono" style="font-size:10px;color:var(--color-ink-4);"><%= role(m) %></span>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
