<div data-controller="qb--expandable"
     data-qb--expandable-open-value="<%= initial_open? ? 'true' : 'false' %>"
     style="border:1px solid var(--color-line);border-radius:10px;background:var(--color-bg-raised);overflow:hidden;">
  <%# Header row %>
  <div style="padding:14px 16px;display:grid;grid-template-columns:auto 1fr auto;gap:14px;align-items:center;border-bottom:1px solid var(--color-line);">
    <div style="display:flex;align-items:center;gap:10px;">
      <% if sub_stages.any? %>
        <button type="button"
                data-action="click->qb--expandable#toggle"
                style="width:24px;height:24px;border-radius:5px;background:var(--color-bg-sunken);border:1px solid var(--color-line);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--color-ink-3);">
          <%= render Qb::IconComponent.new(name: :'chevron-right', size: 12, css_class: 'qb-chevron') %>
        </button>
      <% else %>
        <span style="width:24px;height:24px;display:inline-block;"></span>
      <% end %>
      <div style="width:34px;height:34px;border-radius:7px;background:<%= status_circle_bg %>;color:<%= status_circle_fg %>;display:flex;align-items:center;justify-content:center;font-family:var(--font-mono);font-weight:600;font-size:13px;">
        <%= stage.code %>
      </div>
    </div>

    <%= link_to constructors_project_stage_path(project, stage),
                data: { turbo_frame: "stage_detail", action: "click->qb--drawer#open" },
                style: "min-width:0;cursor:pointer;text-align:left;color:inherit;display:block;width:100%;text-decoration:none;" do %>
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:3px;flex-wrap:wrap;">
        <h3 style="margin:0;font-size:15px;font-weight:600;color:var(--color-ink);"><%= stage.name %></h3>
        <%= render Qb::PillComponent.new(tone: stage.status_tone, compact: true) { stage.status_label } %>
        <% if stage.overdue? %><%= render Qb::PillComponent.new('Atrasada', tone: :bad, compact: true) %><% end %>
        <% if sub_stages.any? %>
          <span class="qb-mono" style="font-size:10px;color:var(--color-ink-4);background:var(--color-bg-sunken);padding:1px 6px;border-radius:3px;"><%= sub_stages.size %> sub-etapas</span>
        <% end %>
      </div>
      <% if stage.description.present? %>
        <div style="font-size:12px;color:var(--color-ink-3);margin-bottom:6px;"><%= stage.description %></div>
      <% end %>
      <div style="display:flex;align-items:center;gap:14px;font-size:11px;color:var(--color-ink-3);flex-wrap:wrap;">
        <% if stage.start_date %>
          <span class="qb-mono" style="display:inline-flex;align-items:center;gap:4px;">
            <%= render Qb::IconComponent.new(name: :calendar, size: 11) %>
            <%= stage.start_label %> → <%= stage.end_label %>
          </span>
        <% end %>
        <% if stage.days_total %><span class="qb-mono" style="color:var(--color-ink-4);"><%= stage.days_total %>d</span><% end %>
        <span style="display:inline-flex;align-items:center;gap:4px;"><%= render Qb::IconComponent.new(name: :person, size: 11) %><%= stage.lead_label %></span>
        <% if stage.docs_count.positive? %><span style="display:inline-flex;align-items:center;gap:3px;"><%= render Qb::IconComponent.new(name: :doc, size: 11) %><%= stage.docs_count %></span><% end %>
        <% if stage.images_count.positive? %><span style="display:inline-flex;align-items:center;gap:3px;"><%= render Qb::IconComponent.new(name: :image, size: 11) %><%= stage.images_count %></span><% end %>
        <% if stage.material_lists_count.positive? %><span style="display:inline-flex;align-items:center;gap:3px;"><%= render Qb::IconComponent.new(name: :materials, size: 11) %><%= stage.material_lists_count %></span><% end %>
      </div>
    <% end %>

    <div style="display:flex;align-items:center;gap:14px;">
      <div style="width:120px;">
        <div style="display:flex;justify-content:space-between;font-size:10px;color:var(--color-ink-4);font-family:var(--font-mono);margin-bottom:3px;">
          <span>AVANCE</span>
          <span class="qb-tnum" style="color:var(--color-ink-2);font-weight:600;"><%= stage.progress_value %>%</span>
        </div>
        <%= render Qb::BarComponent.new(value: stage.progress_value, tone: stage.status == :done ? :ok : stage.status == :doing ? :accent : :muted, height: 4) %>
      </div>
      <% if stage.budget.positive? %>
        <div style="width:140px;text-align:right;">
          <div style="display:flex;justify-content:space-between;font-size:10px;color:var(--color-ink-4);font-family:var(--font-mono);margin-bottom:3px;">
            <span>PRESUPUESTO</span>
            <span class="qb-tnum" style="color:<%= stage.spent_pct > 100 ? 'var(--color-bad)' : 'var(--color-ink-2)' %>;font-weight:600;"><%= stage.spent_pct %>%</span>
          </div>
          <div class="qb-mono qb-tnum" style="font-size:11px;color:var(--color-ink-2);"><%= helpers.qb_fmt_ars(stage.spent) %> <span style="color:var(--color-ink-4);">/ <%= helpers.qb_fmt_ars(stage.budget) %></span></div>
        </div>
      <% end %>
      <div style="display:flex;gap:4px;">
        <%= render Qb::BtnComponent.new('', variant: :ghost, size: :xs, icon: :edit, href: edit_constructors_project_stage_path(project, stage), data: { turbo_frame: 'project_modal' }) %>
      </div>
    </div>
  </div>

  <%# Sub-stages table (collapsible body) %>
  <% if sub_stages.any? %>
    <div data-qb--expandable-target="body">
      <div style="display:grid;grid-template-columns:42px 60px 1fr 180px 100px 100px 90px 40px;gap:0;padding:6px 16px;background:var(--color-bg-sunken);font-size:10px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.5px;font-weight:500;border-bottom:1px solid var(--color-line);">
        <span></span><span>Código</span><span>Sub-etapa</span><span>Período</span><span style="text-align:right;">Días</span><span style="text-align:right;">Avance</span><span style="text-align:right;">Adjuntos</span><span></span>
      </div>
      <% sub_stages.each do |sub| %>
        <%= link_to constructors_project_stage_path(project, sub), style: 'display:grid;grid-template-columns:42px 60px 1fr 180px 100px 100px 90px 40px;gap:0;padding:8px 16px;border-bottom:1px solid var(--color-line);cursor:pointer;align-items:center;font-size:12px;text-decoration:none;color:inherit;' do %>
          <div style="padding-left:8px;"><%= render Qb::StatusDotComponent.new(tone: sub.status_tone == :muted ? :muted : (sub.status == :done ? :ok : :info)) %></div>
          <span class="qb-mono" style="font-size:11px;color:var(--color-ink-3);"><%= sub.code %></span>
          <div style="color:var(--color-ink);font-weight:500;"><%= sub.name %></div>
          <span class="qb-mono" style="font-size:11px;color:var(--color-ink-3);"><%= sub.start_date ? "#{sub.start_label} → #{sub.end_label}" : '—' %></span>
          <span class="qb-mono qb-tnum" style="font-size:11px;color:var(--color-ink-3);text-align:right;"><%= sub.days_total ? "#{sub.days_total}d" : '—' %></span>
          <div style="display:flex;align-items:center;gap:6px;justify-content:flex-end;">
            <div style="width:40px;"><%= render Qb::BarComponent.new(value: sub.progress_value, tone: sub.status == :done ? :ok : sub.status == :doing ? :accent : :muted, height: 3) %></div>
            <span class="qb-mono qb-tnum" style="font-size:11px;color:var(--color-ink-2);min-width:28px;text-align:right;"><%= sub.progress_value %>%</span>
          </div>
          <div style="text-align:right;font-size:11px;color:var(--color-ink-4);" class="qb-mono">
            <%= (sub.docs_count.positive? || sub.images_count.positive?) ? "#{sub.docs_count}d · #{sub.images_count}f" : '—' %>
          </div>
          <%= render Qb::IconComponent.new(name: :'chevron-right', size: 13, style: 'color:var(--color-ink-4)') %>
        <% end %>
      <% end %>
      <div style="padding:8px 16px;background:var(--color-bg-sunken);">
        <%= render Qb::BtnComponent.new(%(Agregar sub-etapa a "#{stage.name}"), variant: :ghost, size: :xs, icon: :plus, href: new_constructors_project_stage_path(project, parent_id: stage.id), data: { turbo_frame: 'project_modal' }) %>
      </div>
    </div>
  <% end %>

</div>
