<%# ① IDENTIDAD ────────────────────────────────────────────── %>
<div class="sd-hero">
  <div class="sd-hero-top">
    <span class="sd-code-pill"><%= stage.code %></span>
    <%= render Qb::PillComponent.new(tone: status_tone) { stage.status_label } %>
    <% if stage.overdue? %>
      <%= render Qb::PillComponent.new(tone: :bad) { "Atrasada" } %>
    <% end %>
  </div>

  <div class="sd-hero-title"><h1><%= stage.name %></h1></div>

  <% if stage.description.present? %>
    <div class="sd-hero-desc"><%= stage.description %></div>
  <% end %>

  <% if stage.object.predecessor.present? %>
    <div class="sd-hero-predecessor">
      <%= render Qb::IconComponent.new(name: :arrow_right, size: 12) %>
      Después de: <%= stage.object.predecessor.name %>
    </div>
  <% end %>
</div>

<%# ② MÉTRICAS ───────────────────────────────────────────────── %>
<div style="padding: 12px 18px; background: var(--color-bg); border-bottom: 1px solid var(--color-line);">
  <div class="sd-progress">
    <span class="sd-progress-num"><%= progress_number %>%</span>
    <div class="sd-progress-info">
      <div class="top">
        <span>Avance</span>
        <% if substage_breakdown.present? %>
          <span><%= substage_breakdown %></span>
        <% else %>
          <span><%= stage.status_label %></span>
        <% end %>
      </div>
      <div class="sd-bar">
        <div style="width: <%= progress_number %>%;"></div>
      </div>
    </div>
  </div>
</div>

<div class="sd-metrics">
  <div class="sd-metric">
    <div class="lbl">Inicio</div>
    <div class="val"><%= stage.start_label %></div>
  </div>
  <div class="sd-metric">
    <div class="lbl">Fin</div>
    <div class="val"><%= stage.end_label %></div>
  </div>
  <div class="sd-metric">
    <div class="lbl">Responsable</div>
    <div class="val"><%= stage.lead_label %></div>
  </div>
</div>
<% if stage.budget.positive? %>
  <div class="sd-metrics">
    <div class="sd-metric">
      <div class="lbl">Presupuesto</div>
      <div class="val qb-mono qb-tnum"><%= helpers.qb_fmt_ars(stage.budget) %></div>
    </div>
    <div class="sd-metric">
      <div class="lbl">Gastado</div>
      <div class="val qb-mono qb-tnum" style="<%= stage.spent_pct > 100 ? 'color:var(--color-bad);' : '' %>">
        <%= helpers.qb_fmt_ars(stage.spent) %>
        <span class="sub"><%= stage.spent_pct %>%</span>
      </div>
    </div>
    <div class="sd-metric"></div>
  </div>
<% end %>

<%# ③ ESTRUCTURA ─────────────────────────────────────────────── %>
<% if sub_stages.any? %>
  <div class="sd-group">
    <div class="sd-group-head">
      <div class="sd-group-head-label">
        <strong>Sub-etapas</strong> · <%= sub_stages.size %>
      </div>
      <%= render Qb::BtnComponent.new('Agregar', variant: :ghost, size: :xs, icon: :plus,
            href: new_constructors_project_stage_path(project, parent_id: stage.id),
            data: { turbo_frame: 'project_modal' }) %>
    </div>
    <% sub_stages.each do |sub| %>
      <%= link_to constructors_project_stage_path(project, sub),
                  class: 'sd-sub-row',
                  data: { turbo_frame: 'stage_detail' } do %>
        <span class="sd-sub-code"><%= sub.code %></span>
        <div>
          <div class="sd-sub-name"><%= sub.name %></div>
          <% if sub.object.start_date %>
            <div class="sd-sub-dates"><%= sub.start_label %> → <%= sub.end_label %></div>
          <% end %>
        </div>
        <div class="sd-bar">
          <div style="width: <%= sub.progress_value %>%;"></div>
        </div>
        <span class="sd-sub-pct"><%= sub.progress_value %>%</span>
      <% end %>
    <% end %>
  </div>
<% end %>

<%# ④ TRABAJO — tabbed panel ─────────────────────────────────── %>
<%= render Qb::TabbedPanelComponent.new do |tp| %>

  <%# Tab: Materiales %>
  <% tp.with_tab(label: "Materiales", count: linked_lists.size) do %>
    <% if linked_lists.empty? %>
      <div class="sd-empty-inline">
        <span class="sd-empty-inline-text"><strong>0 listas de materiales</strong> vinculadas a esta etapa.</span>
        <%= render Qb::BtnComponent.new('Nueva lista', variant: :primary, size: :xs, icon: :plus,
              href: new_constructors_project_material_list_path(project, project_stage_id: stage.id),
              data: { turbo_frame: 'project_modal' }) %>
      </div>
    <% else %>
      <div class="sd-tab-actions">
        <%= render Qb::BtnComponent.new('Nueva lista', variant: :primary, size: :xs, icon: :plus,
              href: new_constructors_project_material_list_path(project, project_stage_id: stage.id),
              data: { turbo_frame: 'project_modal' }) %>
      </div>
      <div class="sd-list">
        <% linked_lists.each do |list| %>
          <%= link_to constructors_project_material_list_path(project, list), class: 'sd-list-row' do %>
            <div class="sd-list-main">
              <div class="sd-list-title">
                <%= "#{list.display_number} #{list.name}".strip %>
                <%= render Qb::PillComponent.new(tone: list_status_tone(list), compact: true) { list_status_label(list) } %>
              </div>
              <div class="sd-list-meta"><%= list.material_items.size %> ítems</div>
            </div>
            <span class="sd-list-side sd-list-value"><%= helpers.qb_fmt_cents(list_total_cents(list)) %></span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%# Tab: Gastos %>
  <% tp.with_tab(label: "Gastos", count: stage.object.expenses.size) do %>
    <div data-controller="qb--modal">
      <% if stage.object.expenses.empty? %>
        <div class="sd-empty-inline">
          <span class="sd-empty-inline-text"><strong>0 gastos</strong> registrados en esta etapa.</span>
          <%= render Qb::BtnComponent.new('Nuevo gasto', variant: :primary, size: :xs, icon: :plus,
                data: { action: 'click->qb--modal#open' }) %>
        </div>
      <% else %>
        <div class="sd-tab-actions">
          <%= render Qb::BtnComponent.new('Nuevo gasto', variant: :primary, size: :xs, icon: :plus,
                data: { action: 'click->qb--modal#open' }) %>
        </div>
        <%= render Constructors::Projects::ExpensesListComponent.new(
              expenses: stage.object.expenses.recent_first,
              project: project,
              stage: stage.object,
              bare: true) %>
      <% end %>
      <%= render Constructors::Projects::ExpenseModalComponent.new(project: project, stage: stage.object) %>
    </div>
  <% end %>

  <%# Tab: Notas %>
  <% tp.with_tab(label: "Notas", count: stage.object.notes.size) do %>
    <div data-controller="qb--modal">
      <% if stage.object.notes.empty? %>
        <div class="sd-empty-inline">
          <span class="sd-empty-inline-text"><strong>0 notas</strong> en esta etapa.</span>
          <%= render Qb::BtnComponent.new('Nueva nota', variant: :primary, size: :xs, icon: :plus,
                data: { action: 'click->qb--modal#open' }) %>
        </div>
      <% else %>
        <div class="sd-tab-actions">
          <%= render Qb::BtnComponent.new('Nueva nota', variant: :primary, size: :xs, icon: :plus,
                data: { action: 'click->qb--modal#open' }) %>
        </div>
        <%= render Constructors::Projects::NotesListComponent.new(
              notes: stage.object.notes.recent_first.includes(:author),
              noteable: stage.object,
              project: project,
              bare: true) %>
      <% end %>
      <%= render Constructors::Projects::NoteModalComponent.new(project: project, stage: stage.object) %>
    </div>
  <% end %>

  <%# Tab: Docs %>
  <% tp.with_tab(label: "Docs", count: stage.docs_count) do %>
    <% if stage.object.documents.empty? %>
      <div class="sd-empty-inline">
        <span class="sd-empty-inline-text"><strong>0 documentos</strong> cargados en esta etapa.</span>
        <%= render Qb::BtnComponent.new('Agregar documentos', variant: :primary, size: :xs, icon: :plus,
              href: new_constructors_project_stage_document_path(project, stage.object),
              data: { turbo_frame: 'project_modal' }) %>
      </div>
    <% else %>
      <div class="sd-tab-actions">
        <%= render Qb::BtnComponent.new('Agregar documentos', variant: :primary, size: :xs, icon: :plus,
              href: new_constructors_project_stage_document_path(project, stage.object),
              data: { turbo_frame: 'project_modal' }) %>
      </div>
      <%= render Constructors::Projects::Stages::AttachmentsSectionComponent.new(
            project: project, stage: stage.object, kind: :documents, bare: true) %>
    <% end %>
  <% end %>

  <%# Tab: Fotos %>
  <% tp.with_tab(label: "Fotos", count: stage.images_count) do %>
    <% if stage.object.images.empty? %>
      <div class="sd-empty-inline">
        <span class="sd-empty-inline-text"><strong>0 imágenes</strong> cargadas en esta etapa.</span>
        <%= render Qb::BtnComponent.new('Agregar imágenes', variant: :primary, size: :xs, icon: :plus,
              href: new_constructors_project_stage_image_path(project, stage.object),
              data: { turbo_frame: 'project_modal' }) %>
      </div>
    <% else %>
      <div class="sd-tab-actions">
        <%= render Qb::BtnComponent.new('Agregar imágenes', variant: :primary, size: :xs, icon: :plus,
              href: new_constructors_project_stage_image_path(project, stage.object),
              data: { turbo_frame: 'project_modal' }) %>
      </div>
      <%= render Constructors::Projects::Stages::AttachmentsSectionComponent.new(
            project: project, stage: stage.object, kind: :images, bare: true) %>
    <% end %>
  <% end %>

<% end %>

<%# Footer ──────────────────────────────────────────────────── %>
<div class="sd-footer">
  <%= render Qb::BtnComponent.new('Eliminar', variant: :danger, size: :xs,
        href: constructors_project_stage_path(project, stage),
        data: { turbo_method: :delete,
                turbo_confirm: '¿Eliminar esta etapa?',
                turbo_frame: '_top' }) %>

  <div class="right">
    <%= render Qb::BtnComponent.new('Duplicar', variant: :secondary, size: :xs,
          href: duplicate_constructors_project_stage_path(project, stage),
          data: { turbo_method: :post, turbo_frame: '_top' }) %>
    <%= render Qb::BtnComponent.new('Editar', variant: :secondary, size: :xs,
          href: edit_constructors_project_stage_path(project, stage),
          data: { turbo_frame: '_top' }) %>
    <%= render Qb::BtnComponent.new('Marcar completada', variant: :primary, size: :xs, icon: :check,
          href: complete_constructors_project_stage_path(project, stage),
          data: { turbo_method: :patch }) %>
  </div>
</div>
