<div style="padding:12px;">
  <div style="width:100%;height:140px;border-radius:6px;border:1px solid var(--color-line);background: radial-gradient(circle at 40% 60%, var(--color-bg-sunken) 0%, var(--color-bg-raised) 70%), repeating-linear-gradient(0deg, transparent, transparent 14px, var(--color-line) 14px, var(--color-line) 15px), repeating-linear-gradient(90deg, transparent, transparent 14px, var(--color-line) 14px, var(--color-line) 15px);position:relative;overflow:hidden;">
    <% if lat.present? && lng.present? %>
      <div style="position:absolute;left:42%;top:52%;width:14px;height:14px;border-radius:999px;background:var(--color-accent);border:3px solid var(--color-bg);box-shadow:0 0 0 2px var(--color-accent);"></div>
      <div style="position:absolute;left:42%;top:52%;width:40px;height:40px;border-radius:999px;background:var(--color-accent);opacity:0.15;transform:translate(-40%, -40%);"></div>
    <% end %>
    <div style="position:absolute;bottom:8px;right:10px;font-family:var(--font-mono);font-size:10px;color:var(--color-ink-3);background:var(--color-bg-raised);padding:2px 6px;border-radius:3px;"><%= coords_label %></div>
  </div>
</div>
