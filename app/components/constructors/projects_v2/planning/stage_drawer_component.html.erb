<div data-qb--drawer-target="dialog"
     class="hidden"
     data-action="click->qb--drawer#backdrop keydown@window->qb--drawer#keydown"
     style="display:none;position:fixed;inset:0;z-index:50;background:rgba(0,0,0,0.32);justify-content:flex-end;">
  <div data-qb--drawer-target="panel"
       style="position:relative;width:520px;max-width:100vw;background:var(--color-bg);border-left:1px solid var(--color-line);display:flex;flex-direction:column;overflow:hidden;height:100vh;">

    <%# Header %>
    <div style="padding:16px 20px 14px;border-bottom:1px solid var(--color-line);display:flex;align-items:flex-start;gap:12px;">
      <div style="width:42px;height:42px;border-radius:8px;flex-shrink:0;background:<%= status_circle_bg %>;color:<%= status_circle_fg %>;display:flex;align-items:center;justify-content:center;font-family:var(--font-mono);font-weight:600;font-size:14px;">
        <%= stage.code %>
      </div>
      <div style="flex:1;min-width:0;">
        <div style="font-size:11px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.7px;">Etapa</div>
        <h2 style="margin:2px 0 0;font-size:17px;font-weight:600;color:var(--color-ink);"><%= stage.name %></h2>
        <% if stage.description.present? %>
          <div style="font-size:12px;color:var(--color-ink-3);margin-top:4px;"><%= stage.description %></div>
        <% end %>
      </div>
      <button type="button" data-action="click->qb--drawer#close"
              style="background:transparent;border:none;color:var(--color-ink-3);cursor:pointer;padding:4px;">
        <%= render Qb::IconComponent.new(name: :x, size: 16) %>
      </button>
    </div>

    <%# Body (scrollable) %>
    <div style="flex:1;overflow:auto;padding:16px;display:flex;flex-direction:column;gap:16px;">

      <%# Metrics grid 2-col %>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
        <div style="padding:10px;border:1px solid var(--color-line);border-radius:6px;background:var(--color-bg-raised);">
          <div style="font-size:10px;font-family:var(--font-mono);color:var(--color-ink-4);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:3px;">Avance</div>
          <div style="font-size:13px;font-weight:500;color:var(--color-ink);margin-bottom:6px;"><%= stage.progress_value %>%</div>
          <%= render Qb::BarComponent.new(value: stage.progress_value, tone: stage.status == :done ? :ok : stage.status == :doing ? :accent : :muted, height: 4) %>
        </div>
        <div style="padding:10px;border:1px solid var(--color-line);border-radius:6px;background:var(--color-bg-raised);">
          <div style="font-size:10px;font-family:var(--font-mono);color:var(--color-ink-4);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:3px;">Estado</div>
          <div style="font-size:13px;font-weight:500;color:var(--color-ink);"><%= stage.status_label %></div>
        </div>
        <div style="padding:10px;border:1px solid var(--color-line);border-radius:6px;background:var(--color-bg-raised);">
          <div style="font-size:10px;font-family:var(--font-mono);color:var(--color-ink-4);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:3px;">Inicio</div>
          <div style="font-size:13px;font-weight:500;color:var(--color-ink);"><%= stage.start_label %></div>
        </div>
        <div style="padding:10px;border:1px solid var(--color-line);border-radius:6px;background:var(--color-bg-raised);">
          <div style="font-size:10px;font-family:var(--font-mono);color:var(--color-ink-4);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:3px;">Fin</div>
          <div style="font-size:13px;font-weight:500;color:var(--color-ink);"><%= stage.end_label %></div>
        </div>
        <% if stage.lead_label != 'Sin asignar' %>
          <div style="padding:10px;border:1px solid var(--color-line);border-radius:6px;background:var(--color-bg-raised);">
            <div style="font-size:10px;font-family:var(--font-mono);color:var(--color-ink-4);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:3px;">Responsable</div>
            <div style="font-size:13px;font-weight:500;color:var(--color-ink);"><%= stage.lead_label %></div>
          </div>
        <% end %>
        <% if stage.budget.positive? %>
          <div style="padding:10px;border:1px solid var(--color-line);border-radius:6px;background:var(--color-bg-raised);">
            <div style="font-size:10px;font-family:var(--font-mono);color:var(--color-ink-4);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:3px;">Presupuesto</div>
            <div class="qb-mono qb-tnum" style="font-size:13px;font-weight:500;color:var(--color-ink);"><%= helpers.qb_fmt_ars(stage.budget) %></div>
          </div>
          <div style="padding:10px;border:1px solid var(--color-line);border-radius:6px;background:var(--color-bg-raised);">
            <div style="font-size:10px;font-family:var(--font-mono);color:var(--color-ink-4);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:3px;">Gastado</div>
            <div class="qb-mono qb-tnum" style="font-size:13px;font-weight:500;color:<%= stage.spent_pct > 100 ? 'var(--color-bad)' : 'var(--color-ink)' %>;"><%= helpers.qb_fmt_ars(stage.spent) %> · <%= stage.spent_pct %>%</div>
          </div>
        <% end %>
      </div>

      <%# Sub-stages mini-list %>
      <% if sub_stages.any? %>
        <div>
          <div style="font-size:11px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:6px;display:flex;align-items:center;justify-content:space-between;">
            <span>Sub-etapas · <%= sub_stages.size %></span>
            <%= render Qb::BtnComponent.new('Agregar', variant: :ghost, size: :xs, icon: :plus, href: new_constructors_project_stage_path(project, parent_id: stage.id), data: { turbo_frame: 'project_modal' }) %>
          </div>
          <div style="border:1px solid var(--color-line);border-radius:6px;overflow:hidden;">
            <% sub_stages.each do |sub| %>
              <%= link_to constructors_project_stage_path(project, sub),
                          style: 'display:grid;grid-template-columns:40px 1fr 60px;gap:10px;padding:8px 10px;border-bottom:1px solid var(--color-line);align-items:center;background:var(--color-bg-raised);text-decoration:none;color:inherit;' do %>
                <span class="qb-mono" style="font-size:11px;color:var(--color-ink-3);"><%= sub.code %></span>
                <div style="min-width:0;">
                  <div style="font-size:12px;font-weight:500;color:var(--color-ink);"><%= sub.name %></div>
                  <% if sub.start_date %>
                    <div class="qb-mono" style="font-size:10px;color:var(--color-ink-4);"><%= sub.start_label %> → <%= sub.end_label %></div>
                  <% end %>
                </div>
                <span class="qb-mono qb-tnum" style="font-size:11px;color:var(--color-ink-2);text-align:right;"><%= sub.progress_value %>%</span>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%# Linked material lists %>
      <div>
        <div style="font-size:11px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:6px;display:flex;align-items:center;justify-content:space-between;">
          <span>Listas de materiales · <%= linked_lists.size %></span>
          <%= render Qb::BtnComponent.new('Nueva lista', variant: :ghost, size: :xs, icon: :plus, href: new_constructors_project_material_list_path(project, project_stage_id: stage.id)) %>
        </div>
        <% if linked_lists.empty? %>
          <div style="padding:16px;text-align:center;color:var(--color-ink-4);font-size:12px;border:1px dashed var(--color-line);border-radius:6px;">Sin listas vinculadas a esta etapa.</div>
        <% else %>
          <div style="display:flex;flex-direction:column;gap:6px;">
            <% linked_lists.each do |list| %>
              <%= link_to constructors_project_material_list_path(project, list),
                          style: 'border:1px solid var(--color-line);border-radius:6px;padding:8px 10px;background:var(--color-bg-raised);text-decoration:none;color:inherit;display:block;' do %>
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:2px;">
                  <span style="font-size:12.5px;font-weight:500;"><%= list.name %></span>
                  <%= render Qb::PillComponent.new(tone: list_status_tone(list), compact: true) { list_status_label(list) } %>
                </div>
                <div style="font-size:11px;color:var(--color-ink-3);display:flex;justify-content:space-between;">
                  <span><%= list.material_items.count %> ítems</span>
                  <span class="qb-mono qb-tnum"><%= helpers.qb_fmt_cents(list_total_cents(list)) %></span>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>
      </div>

      <%# Documents / images %>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">
        <div style="border:1px solid var(--color-line);border-radius:6px;padding:12px;background:var(--color-bg-raised);">
          <div style="font-size:10px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:4px;">Documentos</div>
          <div style="display:flex;align-items:baseline;gap:6px;">
            <span class="qb-mono qb-tnum" style="font-size:22px;font-weight:500;"><%= stage.docs_count %></span>
            <span style="font-size:11px;color:var(--color-ink-3);">archivos</span>
          </div>
        </div>
        <div style="border:1px solid var(--color-line);border-radius:6px;padding:12px;background:var(--color-bg-raised);">
          <div style="font-size:10px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.7px;margin-bottom:4px;">Imágenes</div>
          <div style="display:flex;align-items:baseline;gap:6px;">
            <span class="qb-mono qb-tnum" style="font-size:22px;font-weight:500;"><%= stage.images_count %></span>
            <span style="font-size:11px;color:var(--color-ink-3);">fotos</span>
          </div>
        </div>
      </div>
    </div>

    <%# Footer %>
    <div style="padding:12px 16px;border-top:1px solid var(--color-line);display:flex;gap:8px;justify-content:flex-end;background:var(--color-bg-raised);">
      <%= render Qb::BtnComponent.new('Editar etapa', variant: :primary, size: :sm, icon: :edit, href: edit_constructors_project_stage_path(project, stage), data: { turbo_frame: 'project_modal' }) %>
    </div>
  </div>
</div>
