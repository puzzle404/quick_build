<div class="qb-tabs-row" style="display:flex;align-items:stretch;border-bottom:1px solid var(--color-line);padding-left:16px;padding-right:12px;gap:2px;background:var(--color-bg-raised);">
  <% tabs.each do |t| %>
    <% if t.href %>
      <%= link_to t.href, style: tab_style(active?(t)) do %>
        <% if t.icon %><%= render Qb::IconComponent.new(name: t.icon, size: 14) %><% end %>
        <%= t.label %>
        <% if t.count %><span class="qb-mono" style="font-size:11px;color:var(--color-ink-4);margin-left:2px;"><%= t.count %></span><% end %>
      <% end %>
    <% else %>
      <button style="<%= tab_style(active?(t)) %>">
        <% if t.icon %><%= render Qb::IconComponent.new(name: t.icon, size: 14) %><% end %>
        <%= t.label %>
        <% if t.count %><span class="qb-mono" style="font-size:11px;color:var(--color-ink-4);margin-left:2px;"><%= t.count %></span><% end %>
      </button>
    <% end %>
  <% end %>
  <div style="flex:1;"></div>
  <% if right? %><%= right %><% end %>
</div>
