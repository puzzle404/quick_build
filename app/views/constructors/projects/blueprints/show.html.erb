<%= render Constructors::Projects::SectionsNavComponent.new(project: @project, current_section: :blueprints) %>

<div class="mt-6 space-y-4">
  <!-- Header -->
  <div class="flex items-center justify-between">
    <div>
      <h1 style="font-size:22px;font-weight:700;color:var(--color-ink);"><%= @blueprint.name %></h1>
      <% if @blueprint.description.present? %>
        <p style="margin-top:4px;font-size:13px;color:var(--color-ink-2);"><%= @blueprint.description %></p>
      <% end %>
    </div>
    <%= render Qb::BtnComponent.new('Volver a planos', variant: :secondary, icon: :arrow_left,
                                    href: constructors_project_blueprints_path(@project)) %>
  </div>

  <!-- Canvas Viewer -->
  <div style="border-radius:var(--radius);border:1px solid var(--color-line);background:var(--color-bg-raised);overflow:hidden;"
       data-controller="blueprint-viewer"
       data-blueprint-viewer-image-url-value="<%= url_for(@blueprint.file) %>"
       data-blueprint-viewer-blueprint-id-value="<%= @blueprint.id %>"
       data-blueprint-viewer-project-id-value="<%= @project.id %>"
       data-blueprint-viewer-scale-ratio-value="<%= @blueprint.scale_ratio || 0 %>"
       data-blueprint-viewer-measurements-value="<%= (@blueprint.measurements['groups'] || []).to_json %>"
       data-blueprint-viewer-construction-items-value="<%= @construction_items.to_json %>">
    <!-- Toolbar -->
    <div style="border-bottom:1px solid var(--color-line);background:var(--color-bg-sunken);padding:10px 16px;">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <span style="font-size:13px;font-weight:500;color:var(--color-ink-2);">Herramientas:</span>
          <div class="flex gap-1" data-blueprint-viewer-target="toolbar">
            <button type="button"
                    data-action="click->blueprint-viewer#zoomIn"
                    style="display:inline-flex;align-items:center;padding:6px 10px;border-radius:var(--radius);border:1px solid var(--color-line-2);background:var(--color-bg-raised);color:var(--color-ink-2);cursor:pointer;"
                    title="Zoom in">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="height:16px;width:16px;">
                <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                <path d="M12 10h-2v2H9v-2H7V9h2V7h1v2h2v1z"/>
              </svg>
            </button>
            <button type="button"
                    data-action="click->blueprint-viewer#zoomOut"
                    style="display:inline-flex;align-items:center;padding:6px 10px;border-radius:var(--radius);border:1px solid var(--color-line-2);background:var(--color-bg-raised);color:var(--color-ink-2);cursor:pointer;"
                    title="Zoom out">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="height:16px;width:16px;">
                <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
                <path d="M7 9h5v1H7z"/>
              </svg>
            </button>
            <button type="button"
                    data-action="click->blueprint-viewer#resetView"
                    style="display:inline-flex;align-items:center;padding:6px 10px;border-radius:var(--radius);border:1px solid var(--color-line-2);background:var(--color-bg-raised);color:var(--color-ink-2);cursor:pointer;"
                    title="Resetear vista">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="height:16px;width:16px;">
                <path d="M12 5V1L7 6l5 5V7c3.31 0 6 2.69 6 6s-2.69 6-6 6-6-2.69-6-6H4c0 4.42 3.58 8 8 8s8-3.58 8-8-3.58-8-8-8z"/>
              </svg>
            </button>
            <div style="width:1px;height:24px;background:var(--color-line);margin:0 8px;"></div>
            <button type="button"
                    data-action="click->blueprint-viewer#toggleScaleTool"
                    data-blueprint-viewer-target="scaleButton"
                    style="display:inline-flex;align-items:center;gap:4px;padding:6px 10px;border-radius:var(--radius);border:1px solid var(--color-line-2);background:var(--color-bg-raised);color:var(--color-ink-2);font-size:13px;cursor:pointer;"
                    class="bp-tool"
                    title="Definir escala dibujando">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="height:16px;width:16px;">
                <path d="M3 17v2h6v-2H3zM3 5v2h10V5H3zm10 16v-2h8v-2h-8v-2h-2v6h2zM7 9v2H3v2h4v2h2V9H7zm14 4v-2H11v2h10zm-6-4h2V7h4V5h-4V3h-2v6z"/>
              </svg>
              <span data-blueprint-viewer-target="scaleButtonText">Dibujar</span>
            </button>
            <button type="button"
                    data-action="click->blueprint-viewer#toggleManualScaleInput"
                    style="display:inline-flex;align-items:center;padding:6px 10px;border-radius:var(--radius);border:1px solid var(--color-line-2);background:var(--color-bg-raised);color:var(--color-ink-2);font-size:13px;cursor:pointer;"
                    title="Ingresar escala manualmente">
              Manual
            </button>
            <div style="width:1px;height:24px;background:var(--color-line);margin:0 8px;"></div>

            <!-- Measurement Tools -->
            <button type="button"
                    data-action="click->blueprint-viewer#setTool"
                    data-tool="line"
                    data-blueprint-viewer-target="toolButton"
                    style="display:inline-flex;align-items:center;padding:6px 10px;border-radius:var(--radius);border:1px solid var(--color-line-2);background:var(--color-bg-raised);color:var(--color-ink-2);cursor:pointer;"
                    class="bp-tool"
                    title="Medir línea">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="height:16px;width:16px;">
                <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"/>
              </svg>
            </button>
            <button type="button"
                    data-action="click->blueprint-viewer#setTool"
                    data-tool="polygon"
                    data-blueprint-viewer-target="toolButton"
                    style="display:inline-flex;align-items:center;padding:6px 10px;border-radius:var(--radius);border:1px solid var(--color-line-2);background:var(--color-bg-raised);color:var(--color-ink-2);cursor:pointer;"
                    class="bp-tool"
                    title="Medir área">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="height:16px;width:16px;">
                <path d="M17 15.7V13c0-2.21-1.79-4-4-4-1.58 0-2.9.96-3.56 2.33l-2.92-2.92 1.41-1.41-1.41-1.41-4.24 4.24 4.24 4.24 1.41-1.41-1.41-1.41 2.92 2.92C8.55 15.53 8 16.7 8 18c0 2.21 1.79 4 4 4 2.21 0 4-1.79 4-4v-2.3l4.9-4.9-1.41-1.41L17 15.7z"/>
              </svg>
            </button>
            <button type="button"
                    data-action="click->blueprint-viewer#setTool"
                    data-tool="marker"
                    data-blueprint-viewer-target="toolButton"
                    style="display:inline-flex;align-items:center;padding:6px 10px;border-radius:var(--radius);border:1px solid var(--color-line-2);background:var(--color-bg-raised);color:var(--color-ink-2);cursor:pointer;"
                    class="bp-tool"
                    title="Marcador">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="height:16px;width:16px;">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
              </svg>
            </button>

            <div style="width:1px;height:24px;background:var(--color-line);margin:0 8px;"></div>

            <!-- AI Analysis Button -->
            <%= button_to constructors_project_blueprint_ai_analyses_path(@project, @blueprint),
                          method: :post,
                          style: "display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:var(--radius);border:1px solid color-mix(in oklab,var(--color-accent) 40%,transparent);background:color-mix(in oklab,var(--color-accent) 10%,transparent);color:var(--color-accent);font-size:13px;cursor:pointer;",
                          title: "Analizar plano con IA",
                          data: { turbo: false } do %>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="height:16px;width:16px;">
                <path d="M16.5 7.5h-9v9h9v-9z"/>
                <path fill-rule="evenodd" d="M8.25 2.75A.75.75 0 019 2h6a.75.75 0 010 1.5H9a.75.75 0 01-.75-.75zm-3 9a.75.75 0 01.75-.75h12a.75.75 0 010 1.5H6a.75.75 0 01-.75-.75zM3 15.75a.75.75 0 01.75-.75h16.5a.75.75 0 010 1.5H3.75a.75.75 0 01-.75-.75z" clip-rule="evenodd"/>
              </svg>
              IA
            <% end %>

            <%= link_to constructors_project_blueprint_ai_analyses_path(@project, @blueprint),
                        style: "display:inline-flex;align-items:center;gap:6px;padding:6px 10px;border-radius:var(--radius);border:1px solid var(--color-line-2);background:var(--color-bg-raised);color:var(--color-ink-2);font-size:13px;",
                        title: "Ver historial de análisis IA" do %>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" style="height:16px;width:16px;">
                <path fill-rule="evenodd" d="M1 4.75C1 3.784 1.784 3 2.75 3h14.5c.966 0 1.75.784 1.75 1.75v10.5A1.75 1.75 0 0117.25 17H2.75A1.75 1.75 0 011 15.25V4.75zm16.5 0a.25.25 0 00-.25-.25H2.75a.25.25 0 00-.25.25v10.5c0 .138.112.25.25.25h14.5a.25.25 0 00.25-.25V4.75z" clip-rule="evenodd"/>
                <path d="M4.75 7a.75.75 0 000 1.5h6.5a.75.75 0 000-1.5h-6.5zm0 3a.75.75 0 000 1.5h3.5a.75.75 0 000-1.5h-3.5z"/>
              </svg>
              Historial
            <% end %>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div style="font-size:13px;color:var(--color-ink-2);">
            <span data-blueprint-viewer-target="scaleIndicator">
              <% if @blueprint.scale_ratio.present? %>
                Escala: 1:<%= number_with_precision(@blueprint.scale_ratio, precision: 0) %>
              <% else %>
                Sin escala definida
              <% end %>
            </span>
          </div>
          <div style="font-size:13px;color:var(--color-ink-2);">
            <span data-blueprint-viewer-target="zoomLevel">100%</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Content with Sidebar -->
    <div class="flex h-[calc(100vh-300px)] min-h-[500px]">
      <!-- Canvas Container -->
      <div class="relative flex-1 overflow-hidden" style="background:var(--color-bg-sunken);">
        <div class="h-full w-full overflow-hidden cursor-grab active:cursor-grabbing"
             data-blueprint-viewer-target="container">
          <canvas
            data-blueprint-viewer-target="canvas"
            class="block"
            style="image-rendering: crisp-edges;">
          </canvas>
        </div>
      </div>

      <!-- Sidebar -->
      <div class="w-80 flex flex-col" style="border-left:1px solid var(--color-line);background:var(--color-bg-raised);">
        <div style="padding:16px;border-bottom:1px solid var(--color-line);background:var(--color-bg-sunken);">
          <div class="flex justify-between items-center mb-2">
            <h3 style="font-weight:500;color:var(--color-ink);font-size:14px;">Mediciones</h3>
          </div>
          <!-- Auto-save status -->
          <div data-blueprint-viewer-target="saveStatus" style="font-size:11px;color:var(--color-ink-3);display:flex;align-items:center;gap:4px;">
            <svg style="height:12px;width:12px;" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span>Guardado automático</span>
          </div>
        </div>
        <div class="flex-1 overflow-y-auto p-4 space-y-3" data-blueprint-viewer-target="measurementsList">
          <!-- Measurements Groups will be inserted here -->
          <div style="text-align:center;font-size:13px;color:var(--color-ink-3);padding:32px 0;">
            No hay mediciones aún
          </div>
        </div>
      </div>
    </div>

    <!-- Material Selection Modal -->
    <div data-blueprint-viewer-target="materialModal"
         class="hidden absolute inset-0 z-50 flex items-center justify-center" style="background:rgba(0,0,0,0.5);">
      <div style="width:100%;max-width:448px;border-radius:var(--radius);background:var(--color-bg-raised);padding:24px;">
        <h3 style="font-size:16px;font-weight:500;color:var(--color-ink);margin-bottom:16px;">
          ¿Qué vas a medir?
        </h3>

        <div class="space-y-4">
          <!-- Construction Items List -->
          <div style="max-height:240px;overflow-y:auto;border:1px solid var(--color-line);border-radius:var(--radius);">
            <div data-blueprint-viewer-target="materialList" style="divide-y:1px solid var(--color-line);">
              <!-- Items will be injected here -->
            </div>
          </div>

          <div class="flex flex-col gap-2">
            <button type="button"
                    data-action="click->blueprint-viewer#selectNoMaterial"
                    style="width:100%;padding:8px 16px;border-radius:var(--radius);border:1px solid var(--color-line-2);background:var(--color-bg-raised);color:var(--color-ink);font-size:13px;cursor:pointer;">
              Solo medir (sin material)
            </button>
            <button type="button"
                    data-action="click->blueprint-viewer#closeMaterialModal"
                    style="width:100%;padding:8px 16px;border-radius:var(--radius);border:none;background:transparent;color:var(--color-ink-3);font-size:13px;cursor:pointer;">
              Cancelar
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Manual Scale Input Modal -->
    <div data-blueprint-viewer-target="manualScaleModal"
         class="hidden absolute inset-0 z-50 flex items-center justify-center" style="background:rgba(0,0,0,0.5);">
      <div style="width:100%;max-width:448px;border-radius:var(--radius);background:var(--color-bg-raised);padding:24px;">
        <h3 style="font-size:16px;font-weight:500;color:var(--color-ink);margin-bottom:16px;">
          Definir Escala Manualmente
        </h3>

        <div class="space-y-4">
          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:var(--color-ink-2);margin-bottom:8px;">
              Opción 1: Píxeles por metro
            </label>
            <div class="flex gap-2">
              <input type="number"
                     data-blueprint-viewer-target="manualScalePixels"
                     class="qb-input flex-1"
                     placeholder="ej: 55.89"
                     step="0.01">
              <span style="display:flex;align-items:center;font-size:13px;color:var(--color-ink-3);">px/m</span>
            </div>
          </div>

          <div style="text-align:center;font-size:13px;color:var(--color-ink-3);">o</div>

          <div>
            <label style="display:block;font-size:13px;font-weight:500;color:var(--color-ink-2);margin-bottom:8px;">
              Opción 2: Escala de plano
            </label>
            <div class="flex gap-2 items-center">
              <span style="font-size:13px;color:var(--color-ink);">1:</span>
              <input type="number"
                     data-blueprint-viewer-target="manualScaleRatio"
                     class="qb-input flex-1"
                     placeholder="ej: 100"
                     step="1">
            </div>
            <p style="margin-top:4px;font-size:11px;color:var(--color-ink-3);">
              Ejemplo: Si el plano dice "1:100", ingresá 100
            </p>
          </div>

          <div class="flex flex-col gap-2 pt-4">
            <button type="button"
                    data-action="click->blueprint-viewer#applyManualScale"
                    style="width:100%;padding:8px 16px;border-radius:var(--radius);border:none;background:var(--color-accent);color:var(--color-accent-ink);font-size:13px;font-weight:500;cursor:pointer;">
              Aplicar Escala
            </button>
            <button type="button"
                    data-action="click->blueprint-viewer#closeManualScaleModal"
                    style="width:100%;padding:8px 16px;border-radius:var(--radius);border:none;background:transparent;color:var(--color-ink-3);font-size:13px;cursor:pointer;">
              Cancelar
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Info Footer -->
    <div style="border-top:1px solid var(--color-line);background:var(--color-bg-sunken);padding:10px 16px;">
      <div class="flex items-center justify-between" style="font-size:11px;color:var(--color-ink-2);">
        <div>
          <span style="font-weight:500;">Archivo:</span> <%= @blueprint.file_name %>
        </div>
        <div>
          <span style="font-weight:500;">Tamaño:</span> <%= number_to_human_size(@blueprint.file_byte_size) if @blueprint.file_byte_size %>
        </div>
        <div>
          <span style="font-weight:500;">Subido:</span> <%= time_ago_in_words(@blueprint.uploaded_at) %> atrás
        </div>
      </div>
    </div>
  </div>
</div>
