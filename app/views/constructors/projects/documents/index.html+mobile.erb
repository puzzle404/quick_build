<% content_for :title, "Documentos · #{@project.name}" %>

<%= render Qb::Mobile::NavBarComponent.new(title: @project.name, back: true, back_href: constructors_project_path(@project)) %>

<div style="padding: 4px 20px 12px;">
  <h1 style="margin: 0; font-size: 24px; font-weight: 700; letter-spacing: -0.5px;">Documentos</h1>
  <div style="font-size: 13px; color: var(--color-ink-3); margin-top: 4px;">
    <%= pluralize(@documents.size, 'archivo') %>
  </div>
</div>

<%# Upload card %>
<div style="padding: 0 16px 14px;">
  <%= form_with url: constructors_project_documents_path(@project), method: :post, local: true, multipart: true do |f| %>
    <%= render Qb::Mobile::CardComponent.new do %>
      <div style="display:flex;align-items:center;gap:12px;">
        <div style="width:48px;height:48px;border-radius:12px;background:color-mix(in oklab, var(--color-accent) 14%, transparent);color:var(--color-accent);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <%= render Qb::Mobile::IconComponent.new(name: 'upload', size: 22, stroke: 2) %>
        </div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:14.5px;font-weight:600;">Subir documento</div>
          <div style="font-size:12px;color:var(--color-ink-3);">PDF, imagen, Excel.</div>
          <input type="file" name="document[files][]" multiple style="margin-top:8px;font-size:13px;"/>
        </div>
      </div>
      <div style="margin-top:10px;">
        <%= f.submit "Subir", class: "m-btn m-btn--sm m-btn--full" %>
      </div>
    <% end %>
  <% end %>
</div>

<%# Search %>
<%= form_with url: constructors_project_documents_path(@project), method: :get, local: true do %>
  <div style="padding: 0 20px 8px;">
    <div style="display:flex;align-items:center;gap:8px;background:var(--color-bg-sunken);border:1px solid var(--color-line);border-radius:12px;padding:0 12px;height:42px;">
      <%= render Qb::Mobile::IconComponent.new(name: 'search', size: 17) %>
      <input type="search" name="q" value="<%= @query %>" placeholder="Buscar por nombre" style="flex:1;border:none;outline:none;background:transparent;font-size:14px;"/>
    </div>
  </div>
<% end %>

<%# Documents list %>
<div style="padding: 4px 16px 16px;">
  <% if @documents.any? %>
    <%= render Qb::Mobile::CardComponent.new(bleed: true) do %>
      <% @documents.each do |doc| %>
        <%
          name = (doc.respond_to?(:file) && doc.file.attached?) ? doc.file.filename.to_s : "Documento ##{doc.id}"
          file_url = (doc.respond_to?(:file) && doc.file.attached?) ? url_for(doc.file) : nil
          size_kb = (doc.respond_to?(:file) && doc.file.attached?) ? (doc.file.byte_size / 1024.0).round : nil
        %>
        <%= link_to file_url || '#', class: 'm-row m-row--tap', target: '_blank' do %>
          <div class="m-row-icon"><%= render Qb::Mobile::IconComponent.new(name: 'doc', size: 17) %></div>
          <div class="m-row-main">
            <div class="m-row-title"><%= name %></div>
            <div class="m-row-subtitle">
              <%= qb_fmt_date_short(doc.created_at) %>
              <% if size_kb %> · <%= size_kb >= 1024 ? "#{(size_kb / 1024.0).round(1)} MB" : "#{size_kb} KB" %><% end %>
            </div>
          </div>
          <span class="m-row-chevron"><%= render Qb::Mobile::IconComponent.new(name: 'chev-right', size: 16, stroke: 2.2) %></span>
        <% end %>
      <% end %>
    <% end %>
  <% else %>
    <%= render Qb::Mobile::CardComponent.new do %>
      <div style="text-align:center;padding:14px 8px;color:var(--color-ink-3);font-size:13.5px;">
        <% if @query.present? %>Sin documentos para "<%= @query %>".<% else %>Sin documentos.<% end %>
      </div>
    <% end %>
  <% end %>
</div>

<div style="height: 24px;"></div>
