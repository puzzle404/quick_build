<%= render Constructors::Projects::SectionsNavComponent.new(project: @project, current_section: :documents) %>

<div class="mt-6 space-y-6">
  <%= render Qb::SectionHeadComponent.new(title: 'Imágenes del proyecto', subtitle: 'Fotografías y evidencias visuales de la obra') %>

  <section class="qb-card">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <h2 style="font-size:15px;font-weight:600;color:var(--color-ink);">Subir imágenes</h2>
      <%= form_with scope: :image, url: constructors_project_images_path(@project), html: { multipart: true }, class: "flex items-center gap-3" do |f| %>
        <label style="display:inline-flex;cursor:pointer;align-items:center;gap:8px;border-radius:var(--radius);border:1px solid var(--color-line);background:var(--color-bg);padding:6px 14px;font-size:13px;font-weight:600;color:var(--color-ink-2);">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" style="height:16px;width:16px;fill:currentColor;"><path d="M19 13v6a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-6H3l9-9l9 9h-2zm-7 5h2v-4h3l-4-4l-4 4h3v4z"/></svg>
          Agregar imágenes
          <%= f.file_field :files, multiple: true, accept: 'image/*', class: 'hidden' %>
        </label>
        <%= render Qb::BtnComponent.new('Subir', variant: :primary, size: :sm, type: 'submit') %>
      <% end %>
    </div>

    <% if @images.any? %>
      <div class="mt-5 grid grid-cols-2 gap-4 sm:grid-cols-3 lg:grid-cols-4">
        <% @images.each do |image| %>
          <div style="overflow:hidden;border-radius:var(--radius);border:1px solid var(--color-line);background:var(--color-bg-sunken);">
            <% if image.file.variable? %>
              <%= image_tag image.file.variant(resize_to_fill: [480, 320]), style: "height:160px;width:100%;object-fit:cover;" %>
            <% else %>
              <div style="display:flex;height:160px;width:100%;align-items:center;justify-content:center;font-size:11px;color:var(--color-ink-4);">Imagen</div>
            <% end %>
            <div style="display:flex;align-items:center;justify-content:space-between;border-top:1px solid var(--color-line);padding:6px 8px;font-size:11px;">
              <span style="overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="<%= image.title.presence || image.file_filename.to_s %>"><%= image.title.presence || image.file_filename.to_s %></span>
              <div style="display:flex;align-items:center;gap:8px;">
                <%= link_to 'Abrir', url_for(image.file), target: '_blank', style: "font-weight:500;color:var(--color-ink-2);" %>
                <%= button_to 'Eliminar', constructors_project_image_path(@project, image), method: :delete, style: "font-weight:500;color:var(--color-bad);background:none;border:none;cursor:pointer;padding:0;font-size:inherit;font-family:inherit;", data: { turbo_confirm: '¿Eliminar esta imagen?' } %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="mt-4 qb-empty">Aún no se cargaron imágenes para este proyecto.</p>
    <% end %>
  </section>
</div>
