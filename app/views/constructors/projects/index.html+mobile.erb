<% content_for :title, "Proyectos · Quick Build" %>

<%# Header with company hint + new project FAB %>
<div style="padding: 10px 20px 4px; display: flex; align-items: center; gap: 12px;">
  <div style="flex: 1;">
    <% if (company_name = (current_user.try(:company)&.name rescue nil)).present? %>
      <div style="font-size: 12px; color: var(--color-ink-3);"><%= company_name %></div>
    <% end %>
    <h1 style="margin: 0; font-size: 28px; font-weight: 700; letter-spacing: -0.5px;">Proyectos</h1>
  </div>
  <%= link_to new_constructors_project_path, "aria-label": "Nuevo proyecto", style: "width:40px;height:40px;border-radius:999px;background:var(--color-accent);color:var(--color-accent-ink);border:none;display:flex;align-items:center;justify-content:center;text-decoration:none;" do %>
    <%= render Qb::Mobile::IconComponent.new(name: 'plus', size: 22, stroke: 2.4) %>
  <% end %>
</div>

<%# Search %>
<%= form_with url: constructors_projects_path, method: :get, local: true, data: { turbo_frame: "_top" } do %>
  <div style="padding: 10px 20px 8px;">
    <div style="display:flex;align-items:center;gap:8px;background:var(--color-bg-sunken);border:1px solid var(--color-line);border-radius:12px;padding:0 12px;height:42px;">
      <%= render Qb::Mobile::IconComponent.new(name: 'search', size: 17) %>
      <input type="search" name="q" value="<%= @query %>" placeholder="Buscar por nombre, código, cliente…" style="flex:1;border:none;outline:none;background:transparent;font-size:14px;"/>
      <% if @status_filter && @status_filter != "all" %>
        <input type="hidden" name="status" value="<%= @status_filter %>"/>
      <% end %>
      <button type="submit" aria-label="Filtrar" style="background:transparent;border:none;display:flex;">
        <%= render Qb::Mobile::IconComponent.new(name: 'filter', size: 18) %>
      </button>
    </div>
  </div>
<% end %>

<%# Status filter tabs (underline) — counts come from @counts %>
<%
  all_count       = @counts_total.to_i
  in_progress_cnt = @counts['in_progress'].to_i
  planned_cnt     = @counts['planned'].to_i
  completed_cnt   = @counts['completed'].to_i

  filters = [
    { key: 'all',         label: 'Todos',        count: all_count,       href: constructors_projects_path(q: @query) },
    { key: 'in_progress', label: 'En obra',      count: in_progress_cnt, href: constructors_projects_path(q: @query, status: 'in_progress') },
    { key: 'planned',     label: 'Planificados', count: planned_cnt,     href: constructors_projects_path(q: @query, status: 'planned') },
    { key: 'completed',   label: 'Finalizados',  count: completed_cnt,   href: constructors_projects_path(q: @query, status: 'completed') }
  ]
%>
<%= render Qb::Mobile::TabsComponent.new(options: filters, value: @status_filter) %>

<%# List %>
<div style="padding: 12px 16px 8px;">
  <% if @projects_decorated.any? %>
    <div style="display:flex;flex-direction:column;gap:10px;">
      <% @projects_decorated.each do |p| %>
        <%= render "constructors/projects/mobile_card", p: p %>
      <% end %>
    </div>
  <% else %>
    <%= render Qb::Mobile::CardComponent.new do %>
      <div style="text-align:center;padding:16px 8px;">
        <div style="font-size:14px;color:var(--color-ink-2);font-weight:600;margin-bottom:4px;">Sin proyectos</div>
        <div style="font-size:12.5px;color:var(--color-ink-3);margin-bottom:14px;">
          <% if @query.present? %>
            No encontramos resultados para "<%= @query %>".
          <% else %>
            Creá tu primer proyecto para empezar.
          <% end %>
        </div>
        <%= render Qb::Mobile::ButtonComponent.new("Nuevo proyecto", variant: :primary, size: :sm, icon: :plus, href: new_constructors_project_path) %>
      </div>
    <% end %>
  <% end %>
</div>

<% if @pagy && @pagy.pages > 1 %>
  <div style="padding: 12px 20px; text-align: center;">
    <% if @pagy.next %>
      <%= link_to "Cargar más",
            constructors_projects_path(page: @pagy.next, q: @query, status: (@status_filter unless @status_filter == 'all')),
            class: 'm-btn m-btn--secondary m-btn--sm',
            style: 'text-decoration:none;display:inline-flex;' %>
    <% end %>
  </div>
<% end %>

<div style="height: 24px;"></div>
