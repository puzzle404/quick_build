<%= render Constructors::Projects::SectionsNavComponent.new(project: @project, current_section: :materials) %>

<div class="mt-6 max-w-4xl space-y-6">
  <%= render Ui::SectionHeaderComponent.new(title: "Editar lista: #{@material_list.display_number} #{@material_list.name}".strip, subtitle: 'Actualizá cantidades, notas o adjuntos para mantener la lista al día.') %>
  <% if policy(@material_list).destroy? %>
    <%= render Qb::BtnComponent.new('Eliminar', variant: :danger, size: :sm,
          href: constructors_project_material_list_path(@project, @material_list),
          data: { turbo_method: :delete, turbo_confirm: '¿Seguro que querés eliminar esta lista?' }) %>
  <% end %>

  <%= render "form" %>
</div>
