<% content_for :title, "Materiales · #{@project.name}" %>

<%= render Qb::Mobile::NavBarComponent.new(title: @project.name, back: true, back_href: constructors_project_path(@project)) do |c| %>
  <% c.with_right do %>
    <%= link_to new_constructors_project_material_list_path(@project), aria: { label: 'Nueva lista' }, style: 'color:var(--color-accent);display:inline-flex;padding:8px;' do %>
      <%= render Qb::Mobile::IconComponent.new(name: 'plus', size: 22) %>
    <% end %>
  <% end %>
<% end %>

<div style="padding: 4px 20px 12px;">
  <h1 style="margin: 0; font-size: 24px; font-weight: 700; letter-spacing: -0.5px;">Materiales</h1>
  <div style="font-size: 13px; color: var(--color-ink-3); margin-top: 4px;">
    <% n = @material_lists_scope.size %><%= n == 1 ? "1 lista" : "#{n} listas" %>
  </div>
</div>

<%# Source filter chips %>
<%
  source_opts = [
    { key: 'all',           label: 'Todas', href: constructors_project_material_lists_path(@project, status: (@status_filter unless @status_filter == 'all')) },
    { key: 'manual',        label: 'Manual',       href: constructors_project_material_lists_path(@project, source: 'manual') },
    { key: 'pdf_upload',    label: 'PDF',          href: constructors_project_material_lists_path(@project, source: 'pdf_upload') },
    { key: 'excel_upload',  label: 'Excel',        href: constructors_project_material_lists_path(@project, source: 'excel_upload') }
  ]
%>
<div style="padding: 4px 16px 4px; display: flex; gap: 8px; overflow-x: auto; scrollbar-width: none;">
  <% source_opts.each do |o| %>
    <%
      active = (@source_filter.to_s == o[:key])
      style = active ? "background:var(--color-ink);color:var(--color-bg);" : "background:var(--color-bg-raised);color:var(--color-ink-2);border:1px solid var(--color-line);"
    %>
    <%= link_to o[:label], o[:href], style: "#{style}padding:8px 14px;border-radius:999px;font-size:13px;font-weight:600;text-decoration:none;white-space:nowrap;" %>
  <% end %>
</div>

<%# Status tabs (underline). Counts come from a fresh scope to avoid the
    ORDER BY from the search service tripping over PG GROUP BY rules.
    `group(:status).count` returns the enum keys as strings ({"draft" => 1, …}). %>
<%
  status_counts = MaterialList.unscoped.where(project_id: @project.id).group(:status).count
  draft_n    = status_counts['draft'].to_i
  review_n   = status_counts['ready_for_review'].to_i
  approved_n = status_counts['approved'].to_i
  all_n      = draft_n + review_n + approved_n

  status_tabs = [
    { key: 'all',              label: 'Todas',       count: all_n,      href: constructors_project_material_lists_path(@project, source: (@source_filter unless @source_filter == 'all')) },
    { key: 'draft',            label: 'Borrador',    count: draft_n,    href: constructors_project_material_lists_path(@project, status: 'draft') },
    { key: 'ready_for_review', label: 'En revisión', count: review_n,   href: constructors_project_material_lists_path(@project, status: 'ready_for_review') },
    { key: 'approved',         label: 'Aprobadas',   count: approved_n, href: constructors_project_material_lists_path(@project, status: 'approved') }
  ]
%>
<%= render Qb::Mobile::TabsComponent.new(options: status_tabs, value: @status_filter) %>

<div style="padding: 12px 16px 8px;">
  <% if @material_lists.any? %>
    <%= render Qb::Mobile::CardComponent.new(bleed: true) do %>
      <% @material_lists.each do |ml| %>
        <%
          items_count = ml.material_items.size
          total_cents = ml.material_items.to_a.sum { |i| i.total_estimated_cost_cents.to_i }
          status_tone = case ml.status
                        when 'approved'         then :ok
                        when 'ready_for_review' then :warn
                        else                         :muted
                        end
          status_label = MaterialList.statuses.key(MaterialList.statuses[ml.status]) || ml.status
          status_label_es = { 'draft' => 'Borrador', 'ready_for_review' => 'En revisión', 'approved' => 'Aprobada' }[ml.status]
        %>
        <%= link_to constructors_project_material_list_path(@project, ml), class: 'm-row m-row--tap' do %>
          <div class="m-row-icon" style="background:color-mix(in oklab, var(--color-accent) 14%, transparent);color:var(--color-accent);">
            <%= render Qb::Mobile::IconComponent.new(name: 'materials', size: 17) %>
          </div>
          <div class="m-row-main">
            <div class="m-row-title"><%= ml.name %></div>
            <div class="m-row-subtitle">
              <%= pluralize(items_count, 'ítem') %> · <%= status_label_es %>
              <% if ml.project_stage %> · <%= ml.project_stage.name %><% end %>
            </div>
          </div>
          <span class="m-row-value m-row-value--mono"><%= qb_fmt_cents(total_cents) %></span>
          <span class="m-row-chevron"><%= render Qb::Mobile::IconComponent.new(name: 'chev-right', size: 16, stroke: 2.2) %></span>
        <% end %>
      <% end %>
    <% end %>
  <% else %>
    <%= render Qb::Mobile::CardComponent.new do %>
      <div style="text-align:center;padding:16px 8px;">
        <div style="font-size:14px;color:var(--color-ink-2);font-weight:600;margin-bottom:4px;">Sin listas de materiales</div>
        <div style="font-size:12.5px;color:var(--color-ink-3);margin-bottom:14px;">Creá la primera lista o subí un PDF / Excel.</div>
        <%= render Qb::Mobile::ButtonComponent.new("Nueva lista", variant: :primary, size: :sm, icon: :plus, href: new_constructors_project_material_list_path(@project)) %>
      </div>
    <% end %>
  <% end %>
</div>

<div style="height: 24px;"></div>
