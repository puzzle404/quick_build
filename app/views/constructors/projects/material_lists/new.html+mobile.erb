<% content_for :title, "Nueva lista · #{@project.name}" %>

<%= render Qb::Mobile::NavBarComponent.new(title: "Nueva lista", back: true, back_href: constructors_project_material_lists_path(@project)) %>

<div style="padding: 4px 20px 12px;">
  <h1 style="margin: 0; font-size: 22px; font-weight: 700; letter-spacing: -0.4px;">Nueva lista de materiales</h1>
  <p style="margin: 4px 0 0; font-size: 13.5px; color: var(--color-ink-3); line-height: 1.4;">
    Manual: empezás vacía. PDF / Excel: subís un archivo y armamos los ítems.
  </p>
</div>

<%= form_with model: @material_list, url: constructors_project_material_lists_path(@project), local: true, html: { multipart: true, style: "padding: 0 16px;" } do |f| %>
  <% if @material_list.errors.any? %>
    <div role="alert" style="margin-bottom:14px;padding:10px 12px;border-radius:10px;background:color-mix(in oklab, var(--color-bad) 12%, transparent);color:var(--color-bad);font-size:13px;">
      <%= @material_list.errors.full_messages.to_sentence %>
    </div>
  <% end %>

  <%= render Qb::Mobile::FormGroupComponent.new(title: "Origen") do %>
    <% MaterialList.source_types.each_key do |kind| %>
      <% label = { 'manual' => 'Manual', 'pdf_upload' => 'Importar PDF', 'excel_upload' => 'Importar Excel' }[kind] %>
      <label class="m-frow-toggle" style="cursor:pointer;">
        <div class="m-frow-toggle-main">
          <div class="m-frow-toggle-title"><%= label %></div>
          <div class="m-frow-toggle-sub">
            <%= { 'manual' => 'Cargás los ítems uno a uno.', 'pdf_upload' => 'Subís un PDF y armamos la lista.', 'excel_upload' => 'Subís un .xlsx y armamos la lista.' }[kind] %>
          </div>
        </div>
        <%= f.radio_button :source_type, kind, style: "accent-color: var(--color-accent); width:20px; height:20px;" %>
      </label>
    <% end %>
  <% end %>

  <%= render Qb::Mobile::FormGroupComponent.new(title: "Datos") do %>
    <%= render Qb::Mobile::FormRowComponent.new(label: "Nombre", name: "material_list[name]", value: @material_list.name, placeholder: "Ej: Hierros · Estructura", required: true) %>
    <%= render Qb::Mobile::FormRowComponent.new(label: "Notas", name: "material_list[notes]", value: @material_list.notes, textarea: true, placeholder: "Contexto, especificaciones técnicas, etc.") %>
    <%= render Qb::Mobile::FormRowComponent.new(
          label: "Etapa", name: "material_list[project_stage_id]", select: true,
          value: @material_list.project_stage_id,
          options: [['— Sin etapa —', '']] + (@project_stages || []).map { |s| [s.name, s.id] }) %>
  <% end %>

  <%# Archivo opcional para PDF/Excel %>
  <%= render Qb::Mobile::FormGroupComponent.new(title: "Archivo (opcional)", footnote: "Sólo si elegiste PDF o Excel arriba.") do %>
    <div class="m-frow">
      <label class="m-frow-label">Archivo</label>
      <%= f.file_field :source_file, accept: "application/pdf,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", class: "m-frow-input" %>
    </div>
  <% end %>

  <div style="display:flex;gap:10px;padding-bottom:24px;">
    <%= link_to "Cancelar", constructors_project_material_lists_path(@project),
          class: "m-btn m-btn--secondary m-btn--md",
          style: "flex:1;text-decoration:none;" %>
    <%= f.submit "Crear lista", class: "m-btn m-btn--md", style: "flex:1.4;" %>
  </div>
<% end %>
