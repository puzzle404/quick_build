<% content_for :title, "#{@material_list.name} · Materiales" %>
<%
  ml = @material_list
  items = @material_items
  total_cents = items.to_a.sum { |i| i.total_estimated_cost_cents.to_i }
  status_label_es = { 'draft' => 'Borrador', 'ready_for_review' => 'En revisión', 'approved' => 'Aprobada' }[ml.status]
  status_tone = case ml.status
                when 'approved'         then :ok
                when 'ready_for_review' then :warn
                else                         :muted
                end
%>

<%= render Qb::Mobile::NavBarComponent.new(title: nil, back: true, back_href: constructors_project_material_lists_path(@project)) do |c| %>
  <% c.with_right do %>
    <%= link_to edit_constructors_project_material_list_path(@project, ml), aria: { label: 'Editar' }, style: 'color:var(--color-accent);padding:8px;display:inline-flex;' do %>
      <%= render Qb::Mobile::IconComponent.new(name: 'edit', size: 20) %>
    <% end %>
  <% end %>
<% end %>

<%# Identity %>
<div style="padding: 4px 20px 14px;">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;flex-wrap:wrap;">
    <% if ml.respond_to?(:display_number) && ml.display_number.present? %>
      <span class="mono" style="font-size:11px;color:var(--color-ink-3);background:var(--color-bg-sunken);padding:3px 8px;border-radius:4px;font-weight:600;"><%= ml.display_number %></span>
    <% end %>
    <%= render Qb::Mobile::PillComponent.new(status_label_es, tone: status_tone, dense: true) %>
    <% if ml.source_type != 'manual' %>
      <%= render Qb::Mobile::PillComponent.new(ml.source_type == 'pdf_upload' ? 'PDF' : 'Excel', tone: :info, dense: true, mono: true) %>
    <% end %>
  </div>
  <h1 style="margin: 0 0 6px; font-size: 24px; font-weight: 700; letter-spacing: -0.4px; line-height: 1.15;"><%= ml.name %></h1>
  <% if ml.notes.present? %>
    <p style="margin: 0; font-size: 13.5px; color: var(--color-ink-3); line-height: 1.45;"><%= ml.notes %></p>
  <% end %>
  <% if ml.project_stage %>
    <div style="margin-top:8px;font-size:12px;color:var(--color-ink-3);">
      <%= render Qb::Mobile::IconComponent.new(name: 'stages', size: 12, css_class: 'inline-icon') %>
      <%= link_to ml.project_stage.name, constructors_project_stage_path(@project, ml.project_stage), style: 'color:var(--color-accent);text-decoration:none;font-weight:500;' %>
    </div>
  <% end %>
</div>

<%# Items list %>
<%= render Qb::Mobile::SectionComponent.new(title: "Ítems · #{items.size}") do |s| %>
  <% s.with_action do %>
    <%= link_to "Agregar", "#item-form", style: "font-size:13px;color:var(--color-accent);font-weight:600;text-decoration:none;" %>
  <% end %>

  <% if items.any? %>
    <%= render Qb::Mobile::CardComponent.new(bleed: true) do %>
      <% items.each do |item| %>
        <div class="m-row">
          <div class="m-row-icon">
            <%= render Qb::Mobile::IconComponent.new(name: 'materials', size: 17) %>
          </div>
          <div class="m-row-main">
            <div class="m-row-title"><%= item.name %></div>
            <div class="m-row-subtitle">
              <span class="mono tnum"><%= item.quantity %></span> <%= item.unit %>
              <% if item.estimated_cost_cents.to_i.positive? %>
                · <%= qb_fmt_cents(item.estimated_cost_cents) %>/u
              <% end %>
            </div>
          </div>
          <span class="m-row-value m-row-value--mono">
            <%= qb_fmt_cents(item.total_estimated_cost_cents.to_i) %>
          </span>
        </div>
      <% end %>
    <% end %>
  <% else %>
    <%= render Qb::Mobile::CardComponent.new do %>
      <div style="text-align:center;padding:14px 8px;color:var(--color-ink-3);font-size:13.5px;">Sin ítems. Agregá el primero abajo.</div>
    <% end %>
  <% end %>
<% end %>

<%# Item form %>
<div id="item-form" style="padding: 0 16px 16px;">
  <%= form_with model: [@project, ml, @material_item], local: true do |f| %>
    <%= render Qb::Mobile::FormGroupComponent.new(title: "Nuevo ítem") do %>
      <%= render Qb::Mobile::FormRowComponent.new(label: "Nombre", name: "material_item[name]", placeholder: "Ej: Cemento Portland 50kg", required: true) %>
      <div style="display:grid;grid-template-columns:1fr 1fr;">
        <%= render Qb::Mobile::FormRowComponent.new(label: "Cantidad", name: "material_item[quantity]", type: 'number', placeholder: "0", required: true) %>
        <%= render Qb::Mobile::FormRowComponent.new(label: "Unidad", name: "material_item[unit]", placeholder: "u, kg, m²", required: true) %>
      </div>
      <%= render Qb::Mobile::FormAmountRowComponent.new(label: "Costo unitario", name: "material_item[estimated_cost_cents]") %>
    <% end %>
    <%= render Qb::Mobile::ButtonComponent.new("Agregar ítem", variant: :primary, size: :md, full: true, type: 'submit', icon: :plus) %>
  <% end %>
</div>

<%# Sticky totals bar %>
<div style="position:sticky;bottom:24px;padding:12px 16px;background:color-mix(in oklab, var(--color-bg) 90%, transparent);backdrop-filter:blur(20px) saturate(180%);-webkit-backdrop-filter:blur(20px) saturate(180%);border-top:0.5px solid var(--color-line);display:flex;align-items:center;justify-content:space-between;gap:12px;">
  <div style="flex:1;min-width:0;">
    <div style="font-size:10.5px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.7px;font-weight:600;">Total estimado</div>
    <div class="mono tnum" style="font-size:20px;font-weight:700;letter-spacing:-0.4px;"><%= qb_fmt_cents(total_cents) %></div>
  </div>
  <% can_toggle = begin; policy(ml).toggle_publication?; rescue StandardError; false; end %>
  <% if can_toggle %>
    <%= button_to toggle_publication_constructors_project_material_list_path(@project, ml),
          method: :patch,
          class: "m-btn m-btn--secondary m-btn--md" do %>
      <%= ml.material_list_publication&.visibility_public? ? "Despublicar" : "Publicar" %>
    <% end %>
  <% end %>
</div>
