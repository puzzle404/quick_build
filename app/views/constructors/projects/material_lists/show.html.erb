<%= render Constructors::Projects::SectionsNavComponent.new(project: @project, current_section: :materials) %>

<div class="space-y-6">
  <div>
    <%= link_to "← Volver a las listas", constructors_project_material_lists_path(@project),
                style: "font-size:13px;font-weight:500;color:var(--color-accent);" %>
  </div>

  <%= render Qb::SectionHeadComponent.new(title: "#{@material_list.display_number} #{@material_list.name}".strip) %>

  <div>
    <p style="font-size:13px;color:var(--color-ink-3);">
      Actualizada <%= time_ago_in_words(@material_list.updated_at) %> atrás ·
      <%= turbo_frame_tag dom_id(@material_list, :items_counter) do %>
        <%= pluralize(@material_items.size, "ítem") %>
      <% end %>
    </p>
    <% if @material_list.project_stage.present? %>
      <p class="mt-2" style="display:inline-flex;align-items:center;gap:8px;border-radius:var(--radius);background:color-mix(in oklab, var(--color-accent) 10%, transparent);padding:4px 12px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--color-accent);">
        Etapa vinculada: <span style="color:var(--color-ink);"><%= project_stage_label(@material_list.project_stage) %></span>
      </p>
    <% end %>
  </div>

  <div class="flex flex-wrap gap-3">
    <% if policy(@material_list).toggle_publication? %>
      <%= render Qb::BtnComponent.new('Alternar presupuesto', variant: :secondary, size: :sm,
            href: toggle_publication_constructors_project_material_list_path(@project, @material_list),
            data: { turbo_method: :patch }) %>
    <% end %>
    <% if policy(@material_list).update? %>
      <%= render Qb::BtnComponent.new('Editar', variant: :primary,
            href: edit_constructors_project_material_list_path(@project, @material_list)) %>
    <% end %>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-6">
      <% if policy(@material_list).update? %>
        <div class="qb-card"
             data-controller="toggle-form"
             data-toggle-form-open-value="<%= @material_item.errors.any? %>">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div>
              <p style="font-size:13px;font-weight:600;color:var(--color-ink);">Cargar materiales</p>
              <p style="font-size:11px;color:var(--color-ink-4);">Sumá insumos de a uno para construir la lista.</p>
            </div>
            <button type="button"
                    style="display:inline-flex;align-items:center;border-radius:var(--radius);border:1px solid var(--color-line);padding:6px 12px;font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--color-ok);transition:border-color 0.1s,background 0.1s;"
                    data-action="toggle-form#toggle"
                    data-toggle-form-target="button"
                    aria-expanded="false">
              <span data-toggle-form-target="buttonLabel">Agregar material</span>
            </button>
          </div>
          <div class="mt-4 hidden" data-toggle-form-target="content">
            <%= turbo_frame_tag dom_id(@material_list, :new_item_frame) do %>
            <%= render Constructors::Projects::MaterialLists::ItemFormComponent.new(
                         project: @project,
                         material_list: @material_list,
                         material_item: @material_item
                       ) %>
            <% end %>
          </div>
        </div>
      <% end %>

      <%= turbo_frame_tag dom_id(@material_list, :items_list) do %>
        <%= render Constructors::Projects::MaterialLists::ItemsTableComponent.new(
                     project: @project,
                     material_list: @material_list,
                     material_items: @material_items,
                     editable: policy(@material_list).update?
                   ) %>
      <% end %>
    </div>

    <div class="space-y-4">
      <div class="qb-card">
        <p class="qb-section-title">Estado</p>
        <p class="mt-2" style="font-size:16px;font-weight:600;color:var(--color-ink);"><%= @material_list.status.humanize %></p>
        <% if @material_list.approved_at.present? %>
          <p class="mt-2" style="font-size:13px;color:var(--color-ink-3);">Aprobada el <%= l(@material_list.approved_at, format: :long) %>.</p>
        <% else %>
          <p class="mt-2" style="font-size:13px;color:var(--color-ink-3);">Actualizá el estado cuando la lista esté validada por tu equipo.</p>
        <% end %>
      </div>

      <div class="qb-card">
        <p class="qb-section-title">Visibilidad</p>
        <% publication = @material_list.material_list_publication %>
        <p class="mt-2" style="font-size:16px;font-weight:600;color:var(--color-ink);">
          <%= publication&.visibility_public? ? "Permitido presupuestar" : "Uso interno" %>
        </p>
        <p class="mt-2" style="font-size:13px;color:var(--color-ink-3);">
          <% if publication&.visibility_public? %>
            Publicada el <%= l(publication.published_at || @material_list.updated_at, format: :long) %>.
          <% else %>
            La lista no está visible para proveedores. Activala cuando quieras solicitar presupuestos.
          <% end %>
        </p>
      </div>

      <div class="qb-card">
        <p class="qb-section-title">Notas</p>
        <p class="mt-2" style="font-size:13px;color:var(--color-ink-2);white-space:pre-line;">
          <%= @material_list.notes.presence || "Sin notas por el momento." %>
        </p>
      </div>

      <% if @material_list.source_file.attached? %>
        <div class="qb-card">
          <p class="qb-section-title">Archivo adjunto</p>
          <%= link_to @material_list.source_file.filename,
                      rails_blob_path(@material_list.source_file, disposition: :attachment),
                      class: "mt-2 inline-flex items-center",
                      style: "font-size:13px;font-weight:600;color:var(--color-accent);" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
