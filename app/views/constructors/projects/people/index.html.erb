<%
  active_count = @people.count { |p| p.status.to_s == 'active' }
  on_leave_count = @people.count { |p| p.status.to_s == 'inactive' }

  tabs = [
    { value: :overview,   label: 'Resumen',       icon: :home,      href: constructors_project_path(@project) },
    { value: :planning,   label: 'Planificación', icon: :planning,  count: @project.project_stages.where(parent_id: nil).count, href: constructors_project_planning_path(@project) },
    { value: :materials,  label: 'Materiales',    icon: :materials, count: @project.material_lists.count, href: constructors_project_material_lists_path(@project) },
    { value: :blueprints, label: 'Planos · IA',   icon: :blueprint, count: @project.blueprints.count, href: constructors_project_blueprints_path(@project) },
    { value: :team,       label: 'Equipo',        icon: :people,    count: @people.size, href: constructors_project_people_path(@project) },
    { value: :docs,       label: 'Documentos',    icon: :docs,      count: @project.documents.count, href: constructors_project_documents_path(@project) },
  ]
%>

<div>
  <%= render Constructors::Projects::HeaderComponent.new(project: @project) %>
  <%= render Qb::TabsComponent.new(tabs: tabs, current: :team) %>

  <%# KPI strip %>
  <div style="display:grid;grid-template-columns:repeat(4, 1fr);border-bottom:1px solid var(--color-line);background:var(--color-bg-raised);">
    <%= render Qb::MetricCellComponent.new(label: 'Personas asignadas', value: @people.size, hint: "#{active_count} activas") %>
    <%= render Qb::MetricCellComponent.new(label: 'En licencia', value: on_leave_count, hint: 'inactivas hoy') %>
    <%= render Qb::MetricCellComponent.new(label: 'Asistencia promedio', value: '—', hint: 'últimos 30 días', tone: :ok) %>
    <%= render Qb::MetricCellComponent.new(label: 'Costo MO', value: '—', hint: 'este mes') %>
  </div>

  <%# Toolbar %>
  <div style="display:flex;align-items:center;padding:10px 16px;gap:8px;border-bottom:1px solid var(--color-line);background:var(--color-bg-raised);">
    <form action="<%= constructors_project_people_path(@project) %>" method="get" style="display:flex;align-items:center;gap:8px;flex:1;">
      <div style="display:flex;align-items:center;gap:6px;padding:0 10px;height:28px;background:var(--color-bg);border:1px solid var(--color-line);border-radius:5px;width:280px;">
        <%= render Qb::IconComponent.new(name: :search, size: 13, style: 'color:var(--color-ink-4)') %>
        <input type="search" name="q" value="<%= @query %>" placeholder="Buscar personas…"
               style="flex:1;border:none;outline:none;background:transparent;font-size:12px;color:var(--color-ink);">
      </div>
    </form>
    <div style="flex:1;"></div>
    <%= render Qb::BtnComponent.new('Marcar asistencia', variant: :secondary, size: :xs, icon: :check) %>
    <%= render Qb::BtnComponent.new('Invitar persona', variant: :primary, size: :xs, icon: :plus, href: new_constructors_project_person_path(@project)) %>
  </div>

  <%# Table %>
  <% if @people.any? %>
    <table style="width:100%;border-collapse:collapse;font-size:12px;">
      <thead>
        <tr style="background:var(--color-bg-raised);">
          <% ['Persona', 'Rol', 'Documento', 'Inicio / Fin', 'Estado', ''].each_with_index do |h, i| %>
            <th style="padding:8px 12px;text-align:<%= i == 4 ? 'right' : 'left' %>;border-bottom:1px solid var(--color-line);font-size:10px;font-family:var(--font-mono);color:var(--color-ink-3);font-weight:500;letter-spacing:0.5px;text-transform:uppercase;"><%= h %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% @people.each do |person| %>
          <tr style="height:40px;border-bottom:1px solid var(--color-line);">
            <td style="padding:0 12px;">
              <div style="display:flex;align-items:center;gap:10px;">
                <%= render Qb::AvatarComponent.new(name: person.full_name, size: 26) %>
                <div>
                  <div style="font-weight:500;color:var(--color-ink);"><%= person.full_name %></div>
                  <% if person.try(:phone).present? %>
                    <div class="qb-mono" style="font-size:10px;color:var(--color-ink-4);"><%= person.phone %></div>
                  <% end %>
                </div>
              </div>
            </td>
            <td style="padding:0 12px;color:var(--color-ink-2);"><%= person.try(:role_title) || '—' %></td>
            <td style="padding:0 12px;color:var(--color-ink-2);"><%= person.try(:document_id) || '—' %></td>
            <td style="padding:0 12px;color:var(--color-ink-3);" class="qb-mono">
              <%= qb_fmt_date_short(person.try(:start_date)) %>
              <% if person.try(:end_date) %>→ <%= qb_fmt_date_short(person.end_date) %><% end %>
            </td>
            <td style="padding:0 12px;text-align:right;">
              <%= render Qb::PillComponent.new(tone: person.status.to_s == 'active' ? :ok : :muted, compact: true) do %>
                <%= person.status.to_s == 'active' ? 'Activa' : 'Licencia' %>
              <% end %>
            </td>
            <td style="padding:0 12px;width:24px;">
              <%= link_to constructors_project_person_path(@project, person), style: 'color:var(--color-ink-4);text-decoration:none;' do %>
                <%= render Qb::IconComponent.new(name: :'chevron-right', size: 14) %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div style="padding:60px;margin:16px;text-align:center;color:var(--color-ink-4);font-size:13px;border:1px dashed var(--color-line);border-radius:10px;">
      <%= render Qb::IconComponent.new(name: :people, size: 28, style: 'margin-bottom:8px;opacity:0.5;') %>
      <div>Todavía no sumaste personas a esta obra.</div>
    </div>
  <% end %>
</div>
