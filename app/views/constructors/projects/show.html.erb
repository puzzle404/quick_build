<%
  tabs = [
    { value: :overview,   label: 'Resumen',       icon: :home,      href: constructors_project_path(@project) },
    { value: :planning,   label: 'Planificación', icon: :planning,  count: @project.stages_count, href: constructors_project_planning_path(@project) },
    { value: :materials,  label: 'Materiales',    icon: :materials, count: @project.material_lists.count, href: constructors_project_material_lists_path(@project) },
    { value: :blueprints, label: 'Planos · IA',   icon: :blueprint, count: @project.blueprints.count, href: constructors_project_blueprints_path(@project) },
    { value: :team,       label: 'Equipo',        icon: :people,    count: @project.people_count, href: constructors_project_people_path(@project) },
    { value: :docs,       label: 'Documentos',    icon: :docs,      count: @project.docs_count, href: constructors_project_documents_path(@project) },
  ]
%>

<div>
  <%= render Constructors::Projects::HeaderComponent.new(project: @project) %>

  <%= render Qb::TabsComponent.new(tabs: tabs, current: :overview) do |c| %>
    <% c.with_right do %>
      <div style="display:flex;gap:4px;align-items:center;padding:0 8px;">
        <%= render Qb::BtnComponent.new('Subir', variant: :ghost, size: :xs, icon: :upload) %>
        <%= render Qb::BtnComponent.new('Asistente IA', variant: :secondary, size: :xs, icon: :ai) %>
      </div>
    <% end %>
  <% end %>

  <div style="display:grid;grid-template-columns:1.5fr 1fr;gap:0;">
    <div style="border-right:1px solid var(--color-line);">
      <%= render Qb::SectionHeadComponent.new(title: 'Curva S · Real vs Plan') do |c| %>
        <% c.with_right { render Qb::BtnComponent.new('PNG', variant: :ghost, size: :xs, icon: :download) } %>
      <% end %>
      <%= render Constructors::Projects::Overview::SCurveComponent.new(project: @project) %>

      <%= render Qb::SectionHeadComponent.new(title: 'Mini-map de obra', subtitle: 'Todas las etapas en una sola vista · color = salud') %>
      <%= render Constructors::Projects::Overview::StageHeatmapComponent.new(stages: @stages_root) %>

      <%= render Qb::SectionHeadComponent.new(title: 'Actividad en este proyecto') %>
      <%= render Constructors::Dashboard::ActivityFeedComponent.new(entries: @activity_entries) %>

      <div class="px-4 py-4 space-y-4">
        <%= render Constructors::Projects::NoteFormComponent.new(noteable: @project, project: @project) %>
        <%= render Constructors::Projects::NotesListComponent.new(
              notes: @project.notes.recent_first,
              noteable: @project,
              project: @project
            ) %>
      </div>
    </div>

    <div>
      <%= render Qb::SectionHeadComponent.new(title: 'Riesgos y bloqueos') %>
      <%= render Constructors::Projects::Overview::RisksPanelComponent.new(project: @project) %>

      <%= render Qb::SectionHeadComponent.new(title: 'Ubicación') %>
      <%= render Constructors::Projects::Overview::MiniMapComponent.new(lat: @project.latitude, lng: @project.longitude) %>

      <div data-controller="qb--modal">
        <%= render Qb::SectionHeadComponent.new(title: 'Equipo asignado') do |c| %>
          <% c.with_right { render Qb::BtnComponent.new('Invitar', variant: :ghost, size: :xs, icon: :plus, data: { action: 'click->qb--modal#open' }) } %>
        <% end %>
        <%= render Constructors::Projects::Overview::TeamChipsComponent.new(members: @members.first(6)) %>
        <%= render Constructors::Projects::Overview::InviteMemberModalComponent.new(project: @project) %>
      </div>

      <%= render Qb::SectionHeadComponent.new(title: 'Documentos recientes') %>
      <%= render Constructors::Projects::Overview::RecentDocsComponent.new(documents: @recent_documents) %>
    </div>
  </div>
</div>
