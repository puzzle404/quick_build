<%# Stage card (mobile). Locals: stage (ProjectStageDecorator), project. %>
<%
  s = stage
  bar_tone = case s.status
             when :done    then :ok
             when :doing   then :accent
             else               :muted
             end
  badge_bg = case s.status
             when :done  then 'color-mix(in oklab, var(--color-ok) 16%, transparent)'
             when :doing then 'color-mix(in oklab, var(--color-accent) 16%, transparent)'
             else             'var(--color-bg-sunken)'
             end
  badge_fg = case s.status
             when :done  then 'var(--color-ok)'
             when :doing then 'var(--color-accent)'
             else             'var(--color-ink-4)'
             end
  subs = (s.try(:sub_stages) || []).to_a
%>

<%= link_to constructors_project_stage_path(project, s), style: "text-decoration:none;color:inherit;display:block;" do %>
  <%= render Qb::Mobile::CardComponent.new(bleed: true) do %>
    <div style="padding:14px;display:flex;align-items:flex-start;gap:12px;">
      <div style="width:38px;height:38px;border-radius:10px;flex-shrink:0;background:<%= badge_bg %>;color:<%= badge_fg %>;display:flex;align-items:center;justify-content:center;font-family:var(--font-mono);font-weight:700;font-size:14px;">
        <%= s.code %>
      </div>
      <div style="flex:1;min-width:0;">
        <div style="display:flex;align-items:center;gap:6px;margin-bottom:3px;flex-wrap:wrap;">
          <span style="font-size:15px;font-weight:600;color:var(--color-ink);"><%= s.name %></span>
          <%= render Qb::Mobile::PillComponent.new(
                s.overdue? ? "Atrasada" : s.status_label,
                tone: s.overdue? ? :warn : s.status_tone,
                dense: true) %>
        </div>
        <div style="font-size:12px;color:var(--color-ink-3);display:flex;flex-wrap:wrap;gap:2px 10px;">
          <% if s.start_date && s.end_date %>
            <span class="mono" style="display:inline-flex;align-items:center;gap:3px;">
              <%= render Qb::Mobile::IconComponent.new(name: 'calendar', size: 11) %>
              <%= s.start_label %> → <%= s.end_label %>
            </span>
          <% end %>
          <% if s.try(:lead).present? %><span>· <%= s.lead %></span><% end %>
        </div>
      </div>
      <div style="text-align:right;flex-shrink:0;">
        <div class="mono tnum" style="font-size:18px;font-weight:700;color:<%= badge_fg %>;letter-spacing:-0.3px;"><%= s.progress_value %>%</div>
        <% if subs.any? %>
          <div style="font-size:10.5px;color:var(--color-ink-4);margin-top:1px;font-family:var(--font-mono);"><%= subs.size %> sub</div>
        <% end %>
      </div>
    </div>
    <div style="padding:0 14px 12px;">
      <%= render Qb::Mobile::BarComponent.new(value: s.progress_value, tone: bar_tone, height: 4) %>
      <% if s.budget.positive? %>
        <div style="font-size:11px;color:var(--color-ink-3);margin-top:8px;font-family:var(--font-mono);">
          <%= qb_fmt_cents(s.spent) %> / <%= qb_fmt_cents(s.budget) %>
        </div>
      <% end %>
    </div>
  <% end %>
<% end %>
