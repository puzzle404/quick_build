<%# Locals: label, value, warn (optional) %>
<%= render Qb::Mobile::CardComponent.new(padding: 12) do %>
  <div style="text-align:center;">
    <div style="font-size:10.5px;font-family:var(--font-mono);color:var(--color-ink-3);text-transform:uppercase;letter-spacing:0.7px;font-weight:600;"><%= label %></div>
    <div class="mono tnum" style="font-size:15px;font-weight:700;margin-top:4px;color:<%= (defined?(warn) && warn) ? 'var(--color-warn)' : 'var(--color-ink)' %>;"><%= value %></div>
  </div>
<% end %>
