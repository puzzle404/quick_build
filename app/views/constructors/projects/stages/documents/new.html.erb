<%= render Constructors::Projects::SectionsNavComponent.new(project: @project, current_section: :planning) %>

<div class="mt-6 space-y-6">
  <header class="space-y-1">
    <h1 style="font-size:22px;font-weight:600;color:var(--color-ink);">Agregar documentos a <%= @stage.name %></h1>
    <p style="font-size:13px;color:var(--color-ink-3);">Seleccioná uno o varios PDF y súbelos para compartirlos con tu equipo.</p>
  </header>

  <section class="qb-card">
    <%= form_with scope: :document, url: constructors_project_stage_documents_path(@project, @stage), multipart: true, class: "space-y-5" do |form| %>
      <div class="qb-field">
        <%= form.label :files, "Seleccionar archivos", class: "qb-label" %>
        <%= form.file_field :files, multiple: true, accept: ".pdf,application/pdf",
                            style: "font-size:12px;color:var(--color-ink-2);width:100%;" %>
        <p style="margin-top:4px;font-size:11px;color:var(--color-ink-3);">Formatos admitidos: PDF (hasta 25 MB cada uno).</p>
      </div>

      <div class="flex items-center gap-3">
        <%= render Qb::BtnComponent.new('Subir documentos', variant: :primary, type: 'submit') %>
        <%= render Qb::BtnComponent.new('Cancelar', variant: :secondary, href: constructors_project_stage_path(@project, @stage)) %>
      </div>
    <% end %>
  </section>
</div>
