<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Quick Build" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= render "layouts/pwa_head" %>

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= render "layouts/ui_kit_head" %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </head>

  <body <%= "data-hotwire-native" if hotwire_native_app? %> class="bg-slate-50 text-slate-900 font-sans antialiased">
    <%= render Layout::NavbarComponent.new(current_user: current_user) if authenticated? %>
    <main class="max-w-7xl mx-auto mt-6 px-4">
      <% if notice %>
        <p class="mb-4 rounded bg-green-100 p-4 text-green-800"><%= notice %></p>
      <% end %>
      <% if alert %>
        <p class="mb-4 rounded bg-red-100 p-4 text-red-800"><%= alert %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
