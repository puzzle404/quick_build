<!DOCTYPE html>
<html lang="es" data-theme="graphite" data-density="cozy" data-layout="sidebar">
  <head>
    <title><%= content_for(:title) || "Quick Build · OS" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500;600&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= render "layouts/ui_kit_head" %>
    <%= stylesheet_link_tag "https://unpkg.com/leaflet/dist/leaflet.css" %>
  </head>

  <body class="qb-os <%= 'data-hotwire-native' if hotwire_native_app? %>"
        data-controller="qb--keyboard qb--tweaks">
    <div style="display:flex;min-height:100vh;">
      <%= render Qb::Layout::SidebarComponent.new(
            current: current_qb_section || :dashboard,
            user: current_user,
            project: current_qb_project,
            project_sub: current_qb_project_sub,
            project_count: (Project.count rescue nil),
            pinned_projects: (Project.order(updated_at: :desc).limit(4).map { ProjectDecorator.new(_1) } rescue []),
            company_name: (current_user.try(:company)&.name rescue nil)
          ) %>

      <main style="flex:1;min-width:0;display:flex;flex-direction:column;">
        <%
          # Topbar values derived from DB so the chip doesn't lie:
          #   · people_on_site → active project_people across owned projects
          #   · has_alerts     → any in-progress project with non-:ok health
          qb_people_on_site = (current_user.owned_projects.joins(:project_people).where(project_people: { status: ProjectPerson.statuses[:active] }).count rescue 0)
          qb_people_on_site = nil if qb_people_on_site.zero?
          qb_has_alerts = (current_user.owned_projects.in_progress.any? { |p| ProjectDecorator.new(p).health != :ok } rescue false)
        %>
        <%= render Qb::Layout::TopbarComponent.new(
              crumbs: (content_for(:qb_crumbs).present? ? JSON.parse(CGI.unescapeHTML(content_for(:qb_crumbs).to_s), symbolize_names: true) : [{label: 'Inicio'}]),
              user: current_user,
              people_on_site: qb_people_on_site,
              has_alerts: qb_has_alerts
            ) %>

        <% if notice %>
          <div role="status" style="margin:12px 16px;padding:8px 12px;background:color-mix(in oklab, var(--color-ok) 14%, transparent);color:var(--color-ok);border-radius:5px;font-size:13px;"><%= notice %></div>
        <% end %>
        <% if alert %>
          <div role="alert" style="margin:12px 16px;padding:8px 12px;background:color-mix(in oklab, var(--color-bad) 14%, transparent);color:var(--color-bad);border-radius:5px;font-size:13px;"><%= alert %></div>
        <% end %>

        <div style="flex:1;min-width:0;">
          <%= yield %>
        </div>
      </main>
    </div>

    <%= render Qb::Layout::CmdPaletteComponent.new(
          projects: (Project.order(:name).limit(20) rescue [])
        ) %>
    <%= render Qb::Layout::TweaksPanelComponent.new %>
  </body>
</html>
